{
	"name": "ds_adlsg2_binary_generic_file",
	"properties": {
		"description": "Generic dataset to get/put source file in binary format from/to  ADLSG2",
		"linkedServiceName": {
			"referenceName": "ADLSG2 TimeAnalytics DEV",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"p_ds_path": {
				"type": "string"
			},
			"p_ds_file": {
				"type": "string"
			},
			"p_ds_filesystem": {
				"type": "string"
			}
		},
		"folder": {
			"name": "Projects/NCSA"
		},
		"annotations": [],
		"type": "Binary",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().p_ds_file",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@dataset().p_ds_path",
					"type": "Expression"
				},
				"fileSystem": {
					"value": "@dataset().p_ds_filesystem",
					"type": "Expression"
				}
			}
		}
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}