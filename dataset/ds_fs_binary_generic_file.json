{
	"name": "ds_fs_binary_generic_file",
	"properties": {
		"description": "Generic dataset to get/put source file in binary format from File Server",
		"linkedServiceName": {
			"referenceName": "ls_network_file_share",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"p_ds_path": {
				"type": "string"
			},
			"p_ds_file": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Binary",
		"typeProperties": {
			"location": {
				"type": "FileServerLocation",
				"fileName": {
					"value": "@dataset().p_ds_file",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@dataset().p_ds_path",
					"type": "Expression"
				}
			}
		}
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}