{
	"name": "ds_adlsg2_orc_generic_file",
	"properties": {
		"description": "Generic ORC dataset connected  to Azure Datalake",
		"linkedServiceName": {
			"referenceName": "ADLSG2 TimeAnalytics DEV",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"p_ds_orc_dir": {
				"type": "string"
			},
			"p_ds_orc_file": {
				"type": "string"
			},
			"p_ds_orc_container": {
				"type": "string"
			}
		},
		"folder": {
			"name": "Projects/NCSA"
		},
		"annotations": [],
		"type": "Orc",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().p_ds_orc_file",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@dataset().p_ds_orc_dir",
					"type": "Expression"
				},
				"fileSystem": {
					"value": "@dataset().p_ds_orc_container",
					"type": "Expression"
				}
			},
			"orcCompressionCodec": "snappy",
			"enablePhysicalSchema": true
		}
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}