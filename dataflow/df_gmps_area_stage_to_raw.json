{
	"name": "df_gmps_area_stage_to_raw",
	"properties": {
		"folder": {
			"name": "Projects/YARD KPI/GMPS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_gmps_area_stg_raw",
						"type": "DatasetReference"
					},
					"name": "GMPSStage"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gen2_gmps_raw_tgt",
						"type": "DatasetReference"
					},
					"name": "MCRRaw"
				}
			],
			"transformations": [
				{
					"name": "SetFileName"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Id as string,",
				"          ContentTypeID as string,",
				"          ContentType as string,",
				"          AREAID as string,",
				"          Modified as string,",
				"          Created as string,",
				"          CreatedById as string,",
				"          ModifiedById as string,",
				"          Owshiddenversion as string,",
				"          Version as string,",
				"          Path as string,",
				"          ComplianceAssetId as string,",
				"          AREANAME as string,",
				"          PHASE as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> GMPSStage",
				"GMPSStage derive(FileName = concat('Project_Data/YARDKPI/GMPS/AREA/',substring(toString(currentTimestamp()),1,4),'/',substring(toString(currentTimestamp()),6,2),'/',substring(toString(currentTimestamp()),9,2),'/','BFY_Area_',replace(replace(toString(currentTimestamp()),'.',''),':',''),'.csv'),",
				"          source_code = 'SYSTEM',",
				"          sub_source_code = 'GMPS',",
				"          create_date_time = currentUTC()) ~> SetFileName",
				"SetFileName sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     rowUrlColumn:'FileName',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          each(match(true()))",
				"     )) ~> MCRRaw"
			]
		}
	}
}