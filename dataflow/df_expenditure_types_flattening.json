{
	"name": "df_expenditure_types_flattening",
	"properties": {
		"folder": {
			"name": "Projects/Payment Dashboard/Expenditure Types"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_xml_expenditure_types_source_stage_decoded_xml",
						"type": "DatasetReference"
					},
					"name": "SrcXMl"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_expenditure_types_source_stage_final_csv",
						"type": "DatasetReference"
					},
					"name": "SnkCsv"
				}
			],
			"transformations": [
				{
					"name": "XmlToCsvflatten"
				},
				{
					"name": "addLoadDetails"
				}
			],
			"scriptLines": [
				"source(output(",
				"          DATA_DS as (G_1 as (ATTRIBUTE1 as string, ATTRIBUTE10 as string, ATTRIBUTE11 as string, ATTRIBUTE12 as string, ATTRIBUTE13 as string, ATTRIBUTE14 as string, ATTRIBUTE15 as string, ATTRIBUTE2 as string, ATTRIBUTE3 as string, ATTRIBUTE4 as string, ATTRIBUTE5 as string, ATTRIBUTE6 as string, ATTRIBUTE7 as string, ATTRIBUTE8 as string, ATTRIBUTE9 as string, ATTRIBUTE_CATEGORY as string, COST_RATE_FLAG as string, DESCRIPTION as string, END_DATE_ACTIVE as string, EXPENDITURE_CATEGORY_ID as string, EXPENDITURE_TYPE_ID as string, EXPENDITURE_TYPE_NAME as string, LAST_UPDATE_DATE as string, PROCEEDS_FLAG as string, REVENUE_CATEGORY_CODE as string, START_DATE_ACTIVE as string, UNIT_OF_MEASURE as string)[])",
				"     ),",
				"     allowSchemaDrift: false,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     validationMode: 'none',",
				"     namespaces: true) ~> SrcXMl",
				"SrcXMl foldDown(unroll(DATA_DS.G_1),",
				"     mapColumn(",
				"          ATTRIBUTE1 = DATA_DS.G_1.ATTRIBUTE1,",
				"          ATTRIBUTE10 = DATA_DS.G_1.ATTRIBUTE10,",
				"          ATTRIBUTE11 = DATA_DS.G_1.ATTRIBUTE11,",
				"          ATTRIBUTE12 = DATA_DS.G_1.ATTRIBUTE12,",
				"          ATTRIBUTE13 = DATA_DS.G_1.ATTRIBUTE13,",
				"          ATTRIBUTE14 = DATA_DS.G_1.ATTRIBUTE14,",
				"          ATTRIBUTE15 = DATA_DS.G_1.ATTRIBUTE15,",
				"          ATTRIBUTE2 = DATA_DS.G_1.ATTRIBUTE2,",
				"          ATTRIBUTE3 = DATA_DS.G_1.ATTRIBUTE3,",
				"          ATTRIBUTE4 = DATA_DS.G_1.ATTRIBUTE4,",
				"          ATTRIBUTE5 = DATA_DS.G_1.ATTRIBUTE5,",
				"          ATTRIBUTE6 = DATA_DS.G_1.ATTRIBUTE6,",
				"          ATTRIBUTE7 = DATA_DS.G_1.ATTRIBUTE7,",
				"          ATTRIBUTE8 = DATA_DS.G_1.ATTRIBUTE8,",
				"          ATTRIBUTE9 = DATA_DS.G_1.ATTRIBUTE9,",
				"          ATTRIBUTE_CATEGORY = DATA_DS.G_1.ATTRIBUTE_CATEGORY,",
				"          COST_RATE_FLAG = DATA_DS.G_1.COST_RATE_FLAG,",
				"          DESCRIPTION = DATA_DS.G_1.DESCRIPTION,",
				"          END_DATE_ACTIVE = DATA_DS.G_1.END_DATE_ACTIVE,",
				"          EXPENDITURE_CATEGORY_ID = DATA_DS.G_1.EXPENDITURE_CATEGORY_ID,",
				"          EXPENDITURE_TYPE_ID = DATA_DS.G_1.EXPENDITURE_TYPE_ID,",
				"          EXPENDITURE_TYPE_NAME = DATA_DS.G_1.EXPENDITURE_TYPE_NAME,",
				"          LAST_UPDATE_DATE = DATA_DS.G_1.LAST_UPDATE_DATE,",
				"          PROCEEDS_FLAG = DATA_DS.G_1.PROCEEDS_FLAG,",
				"          REVENUE_CATEGORY_CODE = DATA_DS.G_1.REVENUE_CATEGORY_CODE,",
				"          START_DATE_ACTIVE = DATA_DS.G_1.START_DATE_ACTIVE,",
				"          UNIT_OF_MEASURE = DATA_DS.G_1.UNIT_OF_MEASURE",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> XmlToCsvflatten",
				"XmlToCsvflatten derive(source_name = 'SYSTEM',",
				"          sub_source_name = 'R2P',",
				"          created_date_time = currentUTC()) ~> addLoadDetails",
				"addLoadDetails sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['Expenditure_Types.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SnkCsv"
			]
		}
	}
}