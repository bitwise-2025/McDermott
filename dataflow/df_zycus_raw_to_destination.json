{
	"name": "df_zycus_raw_to_destination",
	"properties": {
		"folder": {
			"name": "Zycus"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_zycus_raw_generic",
						"type": "DatasetReference"
					},
					"name": "UncleanedProcessed"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_zycus_raw_generic",
						"type": "DatasetReference"
					},
					"name": "CleanedProcessed"
				}
			],
			"transformations": [
				{
					"name": "CleaningData",
					"description": "1. Cleaning & updating the Description Column\n2. Concating the File_Path as Folder_TimeStamp"
				}
			],
			"scriptLines": [
				"parameters{",
				"     p_df_file_name as string",
				"}",
				"source(output(",
				"          PROJ_ID as string,",
				"          PROJECT_DESCRIPTION as string,",
				"          JDE_PROJ_NUMBER as string,",
				"          OPERATING_GROUP as string,",
				"          SECTOR as string,",
				"          Client as string,",
				"          JDE_SUPPLIER_NUMBER as string,",
				"          IDENT as string,",
				"          Description as string,",
				"          TAG_NUMBER as string,",
				"          SUPPLIER_NAME as string,",
				"          PO_NUMBER as string,",
				"          SPM_POH_ID as string,",
				"          SUPPLEMENT as string,",
				"          SUP_POH_ID as string,",
				"          POLI_POS as string,",
				"          POLI_SUB_POS as string,",
				"          ITEM_SHIP_POS as string,",
				"          ITEM_SHIP_SUB_POS as string,",
				"          FREIGHT_TERM as string,",
				"          POLI_QTY as string,",
				"          UOM as string,",
				"          ISH_PROM_CONTRACT_DATE as string,",
				"          MATL_RECV_DATE as string,",
				"          ISH_ITEM_SHIP_QTY as string,",
				"          RECV_QTY as string,",
				"          RECV_TYPE as string,",
				"          RECV_DOC_NUMBER as string,",
				"          JDE_PO_NUMBER as string,",
				"          JDE_PO_LINE as string,",
				"          ORDER_TYPE as string,",
				"          ORDER_SUFFIX as string,",
				"          ORDER_COMPANY as string,",
				"          ACCOUNT_COMPANY as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> UncleanedProcessed",
				"UncleanedProcessed derive(Description = replace(replace(replace(replace(replace(replace(replace(Description, ',',' '),'\\n',' '),'\"',' '),'\\r',' '),'  ',' '),';',' '),'=-',' '),",
				"     partitionBy('hash', 1)) ~> CleaningData",
				"CleaningData sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Name as string,",
				"          Category as string,",
				"          Status as string,",
				"          Error as string",
				"     ),",
				"     partitionFileNames:[($p_df_file_name)],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> CleanedProcessed"
			]
		}
	}
}