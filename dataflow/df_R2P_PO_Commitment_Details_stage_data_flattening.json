				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     validationMode: 'none',",
				"     namespaces: true) ~> SrcXMl",
				"SrcXMl foldDown(unroll(DATA_DS.G_1),",
				"     mapColumn(",
				"          AMOUNT_ORDERED = DATA_DS.G_1.AMOUNT_ORDERED,",
				"          AREA = DATA_DS.G_1.AREA,",
				"          CONTRACTID = DATA_DS.G_1.CONTRACTID,",
				"          CONVERSION_RATE = DATA_DS.G_1.CONVERSION_RATE,",
				"          COSTOBJECTID = DATA_DS.G_1.COSTOBJECTID,",
				"          DISTRIBUTION_NUM = DATA_DS.G_1.DISTRIBUTION_NUM,",
				"          ENTITYID = DATA_DS.G_1.ENTITYID,",
				"          EXPENDITURETYPE = DATA_DS.G_1.EXPENDITURETYPE,",
				"          FEATURECODE = DATA_DS.G_1.FEATURECODE,",
				"          ITEM_DESCRIPTION = DATA_DS.G_1.ITEM_DESCRIPTION,",
				"          ITEM_ID = DATA_DS.G_1.ITEM_ID,",
				"          ITEM_NUMBER = DATA_DS.G_1.ITEM_NUMBER,",
				"          JOBNUMBERID = DATA_DS.G_1.JOBNUMBERID,",
				"          LATEST_STATUS = DATA_DS.G_1.LATEST_STATUS,",
				"          LEDGERAMOUNTINVOICED = DATA_DS.G_1.LEDGERAMOUNTINVOICED,",
				"          LEDGERAMOUNTOPEN = DATA_DS.G_1.LEDGERAMOUNTOPEN,",
				"          LEDGERCURRENCY = DATA_DS.G_1.LEDGERCURRENCY,",
				"          LEDGERCURRENCYAMOUNT = DATA_DS.G_1.LEDGERCURRENCYAMOUNT,",
				"          LINE_AMOUNT_RECEIVED = DATA_DS.G_1.LINE_AMOUNT_RECEIVED,",
				"          MPP_PO = DATA_DS.G_1.MPP_PO,",
				"          MRRINVOICEAMOUNT = DATA_DS.G_1.MRRINVOICEAMOUNT,",
				"          ONEMDRCOSTTYPE = DATA_DS.G_1.ONEMDRCOSTTYPE,",
				"          OPENCOMMITMENTAMOUNT = DATA_DS.G_1.OPENCOMMITMENTAMOUNT,",
				"          POCLOSEDDATE = DATA_DS.G_1.POCLOSEDDATE,",
				"          PODESCRIPTION = DATA_DS.G_1.PODESCRIPTION,",
				"          PONUMBER = DATA_DS.G_1.PONUMBER,",
				"          POPROJECT = DATA_DS.G_1.POPROJECT,",
				"          POREV = DATA_DS.G_1.POREV,",
				"          POREVCOUNT = DATA_DS.G_1.POREVCOUNT,",
				"          POTITLE = DATA_DS.G_1.POTITLE,",
				"          POVENDOR1 = DATA_DS.G_1.POVENDOR1,",
				"          PO_LINE_NUM = DATA_DS.G_1.PO_LINE_NUM,",
				"          PO_MATCH_APPROVAL_LEVEL = DATA_DS.G_1.PO_MATCH_APPROVAL_LEVEL,",
				"          PURCHASE_BASIS = DATA_DS.G_1.PURCHASE_BASIS,",
				"          QUANTITY = DATA_DS.G_1.QUANTITY,",
				"          RATE = DATA_DS.G_1.RATE,",
				"          REFERENCE = DATA_DS.G_1.REFERENCE,",
				"          REQUISTIONNUMBER = DATA_DS.G_1.REQUISTIONNUMBER,",
				"          STATUS = DATA_DS.G_1.STATUS,",
				"          SUBFUNCTIONID = DATA_DS.G_1.SUBFUNCTIONID,",
				"          TASKNAME = DATA_DS.G_1.TASKNAME,",
				"          TASKNUMBER = DATA_DS.G_1.TASKNUMBER,",
				"          TASKORGAREA = DATA_DS.G_1.TASKORGAREA,",
				"          TASKORGLE = DATA_DS.G_1.TASKORGLE,",
				"          TRANSACTIONAMOUNT = DATA_DS.G_1.TRANSACTIONAMOUNT,",
				"          TRANSACTIONAMOUNTUSD = DATA_DS.G_1.TRANSACTIONAMOUNTUSD,",
				"          TRANSACTIONCURRENCY = DATA_DS.G_1.TRANSACTIONCURRENCY,",
				"          UNITOFMEASUREID = DATA_DS.G_1.UNITOFMEASUREID,",
				"          USD_RATE = DATA_DS.G_1.USD_RATE,",
				"          CURRDATE = DATA_DS.G_2.CURRDATE,",
				"          PO = DATA_DS.PO,",
				"          P_PROJECT = DATA_DS.P_PROJECT,",
				"          P_RUN_DATE = DATA_DS.P_RUN_DATE,",
				"          P_START_DATE = DATA_DS.P_START_DATE",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> XmlToCsvflatten",
				"XmlToCsvflatten derive(source_name = 'SYSTEM',",
				"          sub_source_name = 'R2P') ~> addLoadDetails",
				"addLoadDetails sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['R2P_PO_Commitment_Details_Report.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SnkCsv"
			]
