			"scriptLines": [
				"source(output(",
				"          DATA_DS as (G_1 as (AMOUNT_ORDERED as string, AREA as string, CONTRACTID as string, CONVERSION_RATE as string, COSTOBJECTID as string, DISTRIBUTION_NUM as string, ENTITYID as string, EXPENDITURETYPE as string, FEATURECODE as string, ITEM_DESCRIPTION as string, ITEM_ID as string, ITEM_NUMBER as string, JOBNUMBERID as string, LATEST_STATUS as string, LEDGERAMOUNTINVOICED as string, LEDGERAMOUNTOPEN as string, LEDGERCURRENCY as string, LEDGERCURRENCYAMOUNT as string, LINE_AMOUNT_RECEIVED as string, MPP_PO as string, MRRINVOICEAMOUNT as string, ONEMDRCOSTTYPE as string, OPENCOMMITMENTAMOUNT as string, POCLOSEDDATE as string, PODESCRIPTION as string, PONUMBER as string, POPROJECT as string, POREV as string, POREVCOUNT as string, POTITLE as string, POVENDOR1 as string, PO_LINE_NUM as string, PO_MATCH_APPROVAL_LEVEL as string, PURCHASE_BASIS as string, QUANTITY as string, RATE as string, REFERENCE as string, REQUISTIONNUMBER as string, STATUS as string, SUBFUNCTIONID as string, TASKNAME as string, TASKNUMBER as string, TASKORGAREA as string, TASKORGLE as string, TRANSACTIONAMOUNT as string, TRANSACTIONAMOUNTUSD as string, TRANSACTIONCURRENCY as string, UNITOFMEASUREID as string, USD_RATE as string)[], G_2 as (CURRDATE as string), PO as string, P_PROJECT as string, P_RUN_DATE as string, P_START_DATE as string)",
				"     ),",
