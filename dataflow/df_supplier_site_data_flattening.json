{
	"name": "df_supplier_site_data_flattening",
	"properties": {
		"folder": {
			"name": "Projects/Payment Dashboard/Supplier Site Data"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_xml_supplier_site_data_source_stage_decoded_xml",
						"type": "DatasetReference"
					},
					"name": "SrcXMl"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_supplier_site_data_source_stage_final_csv",
						"type": "DatasetReference"
					},
					"name": "SnkCsv"
				}
			],
			"transformations": [
				{
					"name": "XmlToCsvflatten"
				},
				{
					"name": "addLoadDetails"
				}
			],
			"scriptLines": [
				"source(output(",
				"          DATA_DS as (G_1 as (ADDRESS1 as string, ADDRESS2 as string, ADDRESS3 as string, ADDRESS4 as string, CITY as string, COUNTRY as string, COUNTY as string, END_DATE_ACTIVE as string, IDENTIFYING_ADDRESS_FLAG as string, LAST_UPDATE_DATE as string, LOCATION_ID as string, PARTY_ID as string, PARTY_SITE_ID as string, PARTY_SITE_NAME as string, PARTY_SITE_NUMBER as string, POSTAL_CODE as string, PROVINCE as string, START_DATE_ACTIVE as string, STATE as string, STATUS as string, STATUS_FLAG as string)[])",
				"     ),",
				"     allowSchemaDrift: false,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     validationMode: 'none',",
				"     namespaces: true) ~> SrcXMl",
				"SrcXMl foldDown(unroll(DATA_DS.G_1),",
				"     mapColumn(",
				"          ADDRESS1 = DATA_DS.G_1.ADDRESS1,",
				"          ADDRESS2 = DATA_DS.G_1.ADDRESS2,",
				"          ADDRESS3 = DATA_DS.G_1.ADDRESS3,",
				"          ADDRESS4 = DATA_DS.G_1.ADDRESS4,",
				"          CITY = DATA_DS.G_1.CITY,",
				"          COUNTRY = DATA_DS.G_1.COUNTRY,",
				"          COUNTY = DATA_DS.G_1.COUNTY,",
				"          END_DATE_ACTIVE = DATA_DS.G_1.END_DATE_ACTIVE,",
				"          IDENTIFYING_ADDRESS_FLAG = DATA_DS.G_1.IDENTIFYING_ADDRESS_FLAG,",
				"          LAST_UPDATE_DATE = DATA_DS.G_1.LAST_UPDATE_DATE,",
				"          LOCATION_ID = DATA_DS.G_1.LOCATION_ID,",
				"          PARTY_ID = DATA_DS.G_1.PARTY_ID,",
				"          PARTY_SITE_ID = DATA_DS.G_1.PARTY_SITE_ID,",
				"          PARTY_SITE_NAME = DATA_DS.G_1.PARTY_SITE_NAME,",
				"          PARTY_SITE_NUMBER = DATA_DS.G_1.PARTY_SITE_NUMBER,",
				"          POSTAL_CODE = DATA_DS.G_1.POSTAL_CODE,",
				"          PROVINCE = DATA_DS.G_1.PROVINCE,",
				"          START_DATE_ACTIVE = DATA_DS.G_1.START_DATE_ACTIVE,",
				"          STATE = DATA_DS.G_1.STATE,",
				"          STATUS = DATA_DS.G_1.STATUS,",
				"          STATUS_FLAG = DATA_DS.G_1.STATUS_FLAG",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> XmlToCsvflatten",
				"XmlToCsvflatten derive(source_name = 'SYSTEM',",
				"          sub_source_name = 'R2P',",
				"          created_date_time = currentUTC()) ~> addLoadDetails",
				"addLoadDetails sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['Supplier_Site_Data.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SnkCsv"
			]
		}
	}
}