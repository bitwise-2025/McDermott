				"          Person_x0020_Responsible = trim(replace(Person_x0020_Responsible, '\\n', ' ')),",
				"          Auditee_x0020_Finding_x0020_Acceptance = trim(replace(Auditee_x0020_Finding_x0020_Acceptance, '\\n', ' ')),",
				"          Auditee_x0020_Finding_x0020_Comments = trim(replace(Auditee_x0020_Finding_x0020_Comments, '\\n', ' ')),",
				"          Completed_x0020_By = trim(replace(Completed_x0020_By, '\\n', ' ')),",
				"          Completion_x0020_Date = trim(replace(Completion_x0020_Date, '\\n', ' ')),",
				"          Final_x0020_Approver = trim(replace(Final_x0020_Approver, '\\n', ' ')),",
				"          Date_x0020_of_x0020_Approval = trim(replace(Date_x0020_of_x0020_Approval, '\\n', ' ')),",
				"          Final_x0020_Approver_x0020_Notes = trim(replace(Final_x0020_Approver_x0020_Notes, '\\n', ' ')),",
				"          Workflow_x0020_Current_x0020_Stage = trim(replace(Workflow_x0020_Current_x0020_Stage, '\\n', ' ')),",
				"          Workflow_x0020_Status = trim(replace(Workflow_x0020_Status, '\\n', ' ')),",
				"          File_Path = concat(concat(trim(substringIndex(File_Path,'/',5),'/'),'/'),substring(toString(currentTimestamp()),1,4),'/',substring(toString(currentTimestamp()),6,2),'/',substring(toString(currentTimestamp()),9,2),'/',split(substringIndex(File_Path,'/',-1),'.')[1],'_',replace(replace(toString(currentTimestamp()),'.',''),':',''),'.csv')) ~> setFileName",
				"setFileName sink(allowSchemaDrift: true,",
