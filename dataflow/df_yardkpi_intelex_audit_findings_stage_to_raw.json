				"          Product_x0020_Line = trim(replace(Product_x0020_Line, '\\n', ' ')),",
				"          Checklist = trim(replace(Checklist, '\\n', ' ')),",
				"          Finding_x0020_Record_x0020_No = trim(replace(Finding_x0020_Record_x0020_No, '\\n', ' ')),",
				"          MDR_x0020_Finding_x0020_No = trim(replace(MDR_x0020_Finding_x0020_No, '\\n', ' ')),",
