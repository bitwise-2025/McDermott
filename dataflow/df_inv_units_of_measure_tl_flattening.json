{
	"name": "df_inv_units_of_measure_tl_flattening",
	"properties": {
		"folder": {
			"name": "Projects/Payment Dashboard/Inv Units Of Measure Tl"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_xml_inv_units_of_measure_tl_source_stage_decoded_xml",
						"type": "DatasetReference"
					},
					"name": "SrcXMl"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_inv_units_of_measure_tl_source_stage_final_csv",
						"type": "DatasetReference"
					},
					"name": "SnkCsv"
				}
			],
			"transformations": [
				{
					"name": "XmlToCsvflatten"
				},
				{
					"name": "addLoadDetails"
				}
			],
			"scriptLines": [
				"source(output(",
				"          DATA_DS as (G_1 as (CREATED_BY as string, CREATION_DATE as string, DESCRIPTION as string, LANGUAGE as string, LAST_UPDATED_BY as string, LAST_UPDATE_DATE as string, LAST_UPDATE_LOGIN as string, OBJECT_VERSION_NUMBER as boolean, SOURCE_LANG as string, UNIT_OF_MEASURE as string, UNIT_OF_MEASURE_ID as long, UOM_PLURAL_DESC as string, UOM_RECIPROCAL_DESC as string)[])",
				"     ),",
				"     allowSchemaDrift: false,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     validationMode: 'none',",
				"     namespaces: true) ~> SrcXMl",
				"SrcXMl foldDown(unroll(DATA_DS.G_1),",
				"     mapColumn(",
				"          CREATED_BY = DATA_DS.G_1.CREATED_BY,",
				"          CREATION_DATE = DATA_DS.G_1.CREATION_DATE,",
				"          DESCRIPTION = DATA_DS.G_1.DESCRIPTION,",
				"          LANGUAGE = DATA_DS.G_1.LANGUAGE,",
				"          LAST_UPDATED_BY = DATA_DS.G_1.LAST_UPDATED_BY,",
				"          LAST_UPDATE_DATE = DATA_DS.G_1.LAST_UPDATE_DATE,",
				"          LAST_UPDATE_LOGIN = DATA_DS.G_1.LAST_UPDATE_LOGIN,",
				"          OBJECT_VERSION_NUMBER = DATA_DS.G_1.OBJECT_VERSION_NUMBER,",
				"          SOURCE_LANG = DATA_DS.G_1.SOURCE_LANG,",
				"          UNIT_OF_MEASURE = DATA_DS.G_1.UNIT_OF_MEASURE,",
				"          UNIT_OF_MEASURE_ID = DATA_DS.G_1.UNIT_OF_MEASURE_ID,",
				"          UOM_PLURAL_DESC = DATA_DS.G_1.UOM_PLURAL_DESC,",
				"          UOM_RECIPROCAL_DESC = DATA_DS.G_1.UOM_RECIPROCAL_DESC",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> XmlToCsvflatten",
				"XmlToCsvflatten derive(source_name = 'SYSTEM',",
				"          sub_source_name = 'R2P',",
				"          created_date_time = currentUTC()) ~> addLoadDetails",
				"addLoadDetails sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['Inv_Units_Of_Measure_Tl.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SnkCsv"
			]
		}
	}
}