{
	"name": "df_exchange_rates_data_flattening",
	"properties": {
		"folder": {
			"name": "Projects/Payment Dashboard/Exchange Rates Data"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_xml_exchange_rates_data_source_stage_decoded_xml",
						"type": "DatasetReference"
					},
					"name": "SrcXMl"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_exchange_rates_data_source_stage_final_csv",
						"type": "DatasetReference"
					},
					"name": "SnkCsv"
				}
			],
			"transformations": [
				{
					"name": "XmlToCsvflatten"
				},
				{
					"name": "addLoadDetails"
				}
			],
			"scriptLines": [
				"source(output(",
				"          DATA_DS as (G_1 as (ATTRIBUTE1 as string, ATTRIBUTE10 as string, ATTRIBUTE11 as string, ATTRIBUTE12 as string, ATTRIBUTE13 as string, ATTRIBUTE14 as string, ATTRIBUTE15 as string, ATTRIBUTE2 as string, ATTRIBUTE3 as string, ATTRIBUTE4 as string, ATTRIBUTE5 as string, ATTRIBUTE6 as string, ATTRIBUTE7 as string, ATTRIBUTE8 as string, ATTRIBUTE9 as string, ATTRIBUTE_CATEGORY as string, ATTRIBUTE_DATE1 as string, ATTRIBUTE_DATE2 as string, ATTRIBUTE_DATE3 as string, ATTRIBUTE_DATE4 as string, ATTRIBUTE_DATE5 as string, ATTRIBUTE_NUMBER1 as string, ATTRIBUTE_NUMBER2 as string, ATTRIBUTE_NUMBER3 as string, ATTRIBUTE_NUMBER4 as string, ATTRIBUTE_NUMBER5 as string, CONVERSION_DATE as string, CONVERSION_RATE as string, CONVERSION_TYPE as string, CREATED_BY as string, CREATION_DATE as string, ENTERPRISE_ID as string, FROM_CURRENCY as string, LAST_UPDATED_BY as string, LAST_UPDATE_DATE as string, LAST_UPDATE_LOGIN as string, OBJECT_VERSION_NUMBER as string, RATE_SOURCE_CODE as string, STATUS_CODE as string, TO_CURRENCY as string)[])",
				"     ),",
				"     allowSchemaDrift: false,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     validationMode: 'none',",
				"     namespaces: true) ~> SrcXMl",
				"SrcXMl foldDown(unroll(DATA_DS.G_1),",
				"     mapColumn(",
				"          ATTRIBUTE1 = DATA_DS.G_1.ATTRIBUTE1,",
				"          ATTRIBUTE10 = DATA_DS.G_1.ATTRIBUTE10,",
				"          ATTRIBUTE11 = DATA_DS.G_1.ATTRIBUTE11,",
				"          ATTRIBUTE12 = DATA_DS.G_1.ATTRIBUTE12,",
				"          ATTRIBUTE13 = DATA_DS.G_1.ATTRIBUTE13,",
				"          ATTRIBUTE14 = DATA_DS.G_1.ATTRIBUTE14,",
				"          ATTRIBUTE15 = DATA_DS.G_1.ATTRIBUTE15,",
				"          ATTRIBUTE2 = DATA_DS.G_1.ATTRIBUTE2,",
				"          ATTRIBUTE3 = DATA_DS.G_1.ATTRIBUTE3,",
				"          ATTRIBUTE4 = DATA_DS.G_1.ATTRIBUTE4,",
				"          ATTRIBUTE5 = DATA_DS.G_1.ATTRIBUTE5,",
				"          ATTRIBUTE6 = DATA_DS.G_1.ATTRIBUTE6,",
				"          ATTRIBUTE7 = DATA_DS.G_1.ATTRIBUTE7,",
				"          ATTRIBUTE8 = DATA_DS.G_1.ATTRIBUTE8,",
				"          ATTRIBUTE9 = DATA_DS.G_1.ATTRIBUTE9,",
				"          ATTRIBUTE_CATEGORY = DATA_DS.G_1.ATTRIBUTE_CATEGORY,",
				"          ATTRIBUTE_DATE1 = DATA_DS.G_1.ATTRIBUTE_DATE1,",
				"          ATTRIBUTE_DATE2 = DATA_DS.G_1.ATTRIBUTE_DATE2,",
				"          ATTRIBUTE_DATE3 = DATA_DS.G_1.ATTRIBUTE_DATE3,",
				"          ATTRIBUTE_DATE4 = DATA_DS.G_1.ATTRIBUTE_DATE4,",
				"          ATTRIBUTE_DATE5 = DATA_DS.G_1.ATTRIBUTE_DATE5,",
				"          ATTRIBUTE_NUMBER1 = DATA_DS.G_1.ATTRIBUTE_NUMBER1,",
				"          ATTRIBUTE_NUMBER2 = DATA_DS.G_1.ATTRIBUTE_NUMBER2,",
				"          ATTRIBUTE_NUMBER3 = DATA_DS.G_1.ATTRIBUTE_NUMBER3,",
				"          ATTRIBUTE_NUMBER4 = DATA_DS.G_1.ATTRIBUTE_NUMBER4,",
				"          ATTRIBUTE_NUMBER5 = DATA_DS.G_1.ATTRIBUTE_NUMBER5,",
				"          CONVERSION_DATE = DATA_DS.G_1.CONVERSION_DATE,",
				"          CONVERSION_RATE = DATA_DS.G_1.CONVERSION_RATE,",
				"          CONVERSION_TYPE = DATA_DS.G_1.CONVERSION_TYPE,",
				"          CREATED_BY = DATA_DS.G_1.CREATED_BY,",
				"          CREATION_DATE = DATA_DS.G_1.CREATION_DATE,",
				"          ENTERPRISE_ID = DATA_DS.G_1.ENTERPRISE_ID,",
				"          FROM_CURRENCY = DATA_DS.G_1.FROM_CURRENCY,",
				"          LAST_UPDATED_BY = DATA_DS.G_1.LAST_UPDATED_BY,",
				"          LAST_UPDATE_DATE = DATA_DS.G_1.LAST_UPDATE_DATE,",
				"          LAST_UPDATE_LOGIN = DATA_DS.G_1.LAST_UPDATE_LOGIN,",
				"          OBJECT_VERSION_NUMBER = DATA_DS.G_1.OBJECT_VERSION_NUMBER,",
				"          RATE_SOURCE_CODE = DATA_DS.G_1.RATE_SOURCE_CODE,",
				"          STATUS_CODE = DATA_DS.G_1.STATUS_CODE,",
				"          TO_CURRENCY = DATA_DS.G_1.TO_CURRENCY",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> XmlToCsvflatten",
				"XmlToCsvflatten derive(source_name = 'SYSTEM',",
				"          sub_source_name = 'R2P',",
				"          created_date_time = currentUTC()) ~> addLoadDetails",
				"addLoadDetails sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['Exchange_Rates_Data.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SnkCsv"
			]
		}
	}
}