{
	"name": "df_inboxtask_plm_raw_to_synapse",
	"properties": {
		"folder": {
			"name": "Projects/NCSA/PLM"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_dt_inboxtask_plm_stage",
						"type": "DatasetReference"
					},
					"name": "SrcInboxTaskDTFile"
				},
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_rf_inboxtask_plm_stage",
						"type": "DatasetReference"
					},
					"name": "SrcInboxTaskRFFile"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_InboxTask_StageJSON",
						"type": "DatasetReference"
					},
					"name": "snkJsonSTG"
				}
			],
			"transformations": [
				{
					"name": "UnpivotInboxTaskDTData"
				},
				{
					"name": "selectInboxTaskRFColumns"
				},
				{
					"name": "joinInboxTaskRFDTData"
				},
				{
					"name": "DerivedColSwapAttributeNames"
				},
				{
					"name": "selectSTGColumns"
				},
				{
					"name": "aggregateKeyColumns"
				},
				{
					"name": "SnkJSONFormat"
				}
			],
			"scriptLines": [
				"parameters{",
				"     p_ds_stgfilepath as string,",
				"     p_ds_snkstgpath as string,",
				"     p_ds_snkstgfilename as string",
				"}",
				"source(output(",
				"          ID as string,",
				"          TYPE as string,",
				"          NAME as string,",
				"          REVISION as string,",
				"          DESCRIPTION as string,",
				"          OWNER as string,",
				"          STATE as string,",
				"          POLICY as string,",
				"          VAULT as string,",
				"          LATESTR as string,",
				"          ORGANIZATION as string,",
				"          PROJECT as string,",
				"          ORIGINATED as string,",
				"          MODIFIED as string,",
				"          TIMESTAMP as string,",
				"          DELETED as string,",
				"          ORIGINATOR as string,",
				"          TASK_REQUIREMENT as string,",
				"          TITLE as string,",
				"          ASSIGNEE_SET_DUE_DATE as string,",
				"          DATE_OFFSET_FROM as string,",
				"          TASK_COMMENTS_NEEDED as string,",
				"          ISSUE_CATEGORY as string,",
				"          ISSUE_CLASSIFICATION as string,",
				"          ALLOW_DELEGATION as string,",
				"          ESCALATION_RECIPIENTS as string,",
				"          ROUTE_TASK_USER as string,",
				"          ROUTE_TASK_USER_COMPANY as string,",
				"          COMMENTS as string,",
				"          REVIEWERS_COMMENTS as string,",
				"          DUE_DATE_OFFSET as string,",
				"          REVIEW_COMMENTS_NEEDED as string,",
				"          REVIEW_TASK as string,",
				"          TEMPLATE_TASK as string,",
				"          ROUTE_INSTRUCTIONS as string,",
				"          ACTUAL_COMPLETION_DATE as string,",
				"          APPROVAL_STATUS as string,",
				"          ROUTE_ACTION as string,",
				"          SCHEDULED_COMPLETION_DATE as string,",
				"          ROUTE_NODE_ID as string,",
				"          APPROVERS_RESPONSIBILITY as string,",
				"          ATTRIBUTEVALUE1 as string,",
				"          ATTRIBUTEVALUE2 as string,",
				"          ATTRIBUTEVALUE3 as string,",
				"          ATTRIBUTEVALUE4 as string,",
				"          ATTRIBUTEVALUE5 as string,",
				"          ATTRIBUTEVALUE6 as string,",
				"          ATTRIBUTEVALUE7 as string,",
				"          ATTRIBUTEVALUE8 as string,",
				"          ATTRIBUTEVALUE9 as string,",
				"          ATTRIBUTEVALUE10 as string,",
				"          ATTRIBUTEVALUE11 as string,",
				"          ATTRIBUTEVALUE12 as string,",
				"          ATTRIBUTEVALUE13 as string,",
				"          ATTRIBUTEVALUE14 as string,",
				"          ATTRIBUTEVALUE15 as string,",
				"          FORECASTDATE as string,",
				"          ROUTE_ID as string,",
				"          PERSON_TYPE as string,",
				"          FIRSTNAME as string,",
				"          LASTNAME as string,",
				"          PROJECT_NUMBER as string,",
				"          MDR_IDOCSDOCID as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     purgeFiles: true,",
				"     multiLineRow: true) ~> SrcInboxTaskDTFile",
				"source(output(",
				"          COLLABSPACE_TASK as string,",
				"          ATTRIBUTE1 as string,",
				"          ATTRIBUTE2 as string,",
				"          ATTRIBUTE3 as string,",
				"          ATTRIBUTE4 as string,",
				"          ATTRIBUTE5 as string,",
				"          ATTRIBUTE6 as string,",
				"          ATTRIBUTE7 as string,",
				"          ATTRIBUTE8 as string,",
				"          ATTRIBUTE9 as string,",
				"          ATTRIBUTE10 as string,",
				"          ATTRIBUTE11 as string,",
				"          ATTRIBUTE12 as string,",
				"          ATTRIBUTE13 as string,",
				"          ATTRIBUTE14 as string,",
				"          ATTRIBUTE15 as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     purgeFiles: true,",
				"     multiLineRow: true) ~> SrcInboxTaskRFFile",
				"SrcInboxTaskDTFile unpivot(output(",
				"          CKey as string,",
				"          RValue as string",
				"     ),",
				"     ungroupBy(PROJECT,",
				"          ID,",
				"          PROJECT_NUMBER,",
				"          MDR_IDOCSDOCID),",
				"     lateral: false,",
				"     ignoreNullPivots: true) ~> UnpivotInboxTaskDTData",
				"SrcInboxTaskRFFile select(mapColumn(",
				"          PROJECT = COLLABSPACE_TASK,",
				"          ATTRIBUTEVALUE1 = ATTRIBUTE1,",
				"          ATTRIBUTEVALUE2 = ATTRIBUTE2,",
				"          ATTRIBUTEVALUE3 = ATTRIBUTE3,",
				"          ATTRIBUTEVALUE4 = ATTRIBUTE4,",
				"          ATTRIBUTEVALUE5 = ATTRIBUTE5,",
				"          ATTRIBUTEVALUE6 = ATTRIBUTE6,",
				"          ATTRIBUTEVALUE7 = ATTRIBUTE7,",
				"          ATTRIBUTEVALUE8 = ATTRIBUTE8,",
				"          ATTRIBUTEVALUE9 = ATTRIBUTE9,",
				"          ATTRIBUTEVALUE10 = ATTRIBUTE10,",
				"          ATTRIBUTEVALUE11 = ATTRIBUTE11,",
				"          ATTRIBUTEVALUE12 = ATTRIBUTE12,",
				"          ATTRIBUTEVALUE13 = ATTRIBUTE13,",
				"          ATTRIBUTEVALUE14 = ATTRIBUTE14,",
				"          ATTRIBUTEVALUE15 = ATTRIBUTE15",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectInboxTaskRFColumns",
				"selectInboxTaskRFColumns, UnpivotInboxTaskDTData join(selectInboxTaskRFColumns@PROJECT == UnpivotInboxTaskDTData@PROJECT,",
				"     joinType:'right',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinInboxTaskRFDTData",
				"joinInboxTaskRFDTData derive(CKey = case(CKey == 'ATTRIBUTEVALUE1',ATTRIBUTEVALUE1,CKey == 'ATTRIBUTEVALUE2', ATTRIBUTEVALUE2,CKey == 'ATTRIBUTEVALUE3', ATTRIBUTEVALUE3,CKey == 'ATTRIBUTEVALUE4', ATTRIBUTEVALUE4,CKey == 'ATTRIBUTEVALUE5', ATTRIBUTEVALUE5,CKey == 'ATTRIBUTEVALUE6', ATTRIBUTEVALUE6,CKey == 'ATTRIBUTEVALUE7', ATTRIBUTEVALUE7,CKey == 'ATTRIBUTEVALUE8', ATTRIBUTEVALUE8,CKey == 'ATTRIBUTEVALUE9', ATTRIBUTEVALUE9,CKey == 'ATTRIBUTEVALUE10', ATTRIBUTEVALUE10,CKey == 'ATTRIBUTEVALUE11', ATTRIBUTEVALUE11,CKey == 'ATTRIBUTEVALUE12', ATTRIBUTEVALUE12,CKey == 'ATTRIBUTEVALUE13', ATTRIBUTEVALUE13,CKey == 'ATTRIBUTEVALUE14', ATTRIBUTEVALUE14,CKey == 'ATTRIBUTEVALUE15', ATTRIBUTEVALUE15,CKey)) ~> DerivedColSwapAttributeNames",
				"DerivedColSwapAttributeNames select(mapColumn(",
				"          PROJECT = selectInboxTaskRFColumns@PROJECT,",
				"          ID,",
				"          PROJECT_NUMBER,",
				"          MDR_IDOCSDOCID,",
				"          CKey,",
				"          RValue",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectSTGColumns",
				"selectSTGColumns aggregate(groupBy(PROJECT,",
				"          ID,",
				"          PROJECT_NUMBER,",
				"          MDR_IDOCSDOCID),",
				"     JSON_ATTRIBUTE = collect(CKey+'::'+replace(replace(RValue,'\\n',' '),'\\r',' '))) ~> aggregateKeyColumns",
				"aggregateKeyColumns derive(JSON_ATTRIBUTE = '{ '+trim(replace(toString(JSON_ATTRIBUTE),'::','\" : \"'),'[]')+' }') ~> SnkJSONFormat",
				"SnkJSONFormat sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:[($p_ds_snkstgfilename)],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          PROJECT,",
				"          ID,",
				"          PROJECT_NUMBER,",
				"          MDR_IDOCSDOCID,",
				"          JSON_ATTRIBUTE",
				"     ),",
				"     partitionBy('hash', 1)) ~> snkJsonSTG"
			]
		}
	}
}