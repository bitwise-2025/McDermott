{
	"name": "df_yardkpi_dc_survey_register_stage_to_raw",
	"properties": {
		"folder": {
			"name": "Projects/YARD KPI/DC Survey Register"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_yardkpi_dc_generic_header",
						"type": "DatasetReference"
					},
					"name": "DCStage"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_yardkpi_dc_default",
						"type": "DatasetReference"
					},
					"name": "DCRaw"
				}
			],
			"transformations": [
				{
					"name": "RemoveLineBreaks"
				},
				{
					"name": "SelectColumns"
				},
				{
					"name": "FlagColumnsEmptyRows"
				},
				{
					"name": "FilterOutEmpyuRows"
				},
				{
					"name": "SelectFinalColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {Project No} as string,",
				"          Discipline as string,",
				"          Platform as string,",
				"          {Report No.} as string,",
				"          {No.} as string,",
				"          {Platform Name} as string,",
				"          {Report Number} as string,",
				"          {Rev.} as string,",
				"          {Desc.} as string,",
				"          {Dwg Ref.} as string,",
				"          {Work Pack No.} as string,",
				"          {Work Pack Title} as string,",
				"          {Date Request} as string,",
				"          {Date Inspect} as string,",
				"          {Date Report} as string,",
				"          {QC RFI/IRN} as string,",
				"          {PCM Status} as string,",
				"          Area as string,",
				"          Stages as string,",
				"          Weightage as string,",
				"          Status as string,",
				"          {Defect Category} as string,",
				"          {Total DC Requested} as string,",
				"          {Total DC Completed} as string,",
				"          {DO NOT DELETED PLEASE 1} as string,",
				"          {DO NOT DELETED PLEASE 2} as string,",
				"          {DO NOT DELETED PLEASE 3} as string,",
				"          {DO NOT DELETED PLEASE 4} as string,",
				"          Remarks as string,",
				"          {TRN NO} as string,",
				"          {SIGN OFF} as string,",
				"          {IRN #} as string,",
				"          DATE as string,",
				"          Misc as string,",
				"          dc_function as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     purgeFiles: true,",
				"     rowUrlColumn: 'File_Path',",
				"     multiLineRow: true) ~> DCStage",
				"SelectColumns derive({Project No} = trim(replace(replace(replace(replace(replace(replace({Project No},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          Discipline = trim(replace(replace(replace(replace(replace(replace(Discipline,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          Platform = trim(replace(replace(replace(replace(replace(replace(Platform,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Report No.} = trim(replace(replace(replace(replace(replace(replace({Report No.},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Platform Name} = trim(replace(replace(replace(replace(replace(replace({Platform Name},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Report Number} = trim(replace(replace(replace(replace(replace(replace({Report Number},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Rev.} = trim(replace(replace(replace(replace(replace(replace({Rev.},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Desc.} = trim(replace(replace(replace(replace(replace(replace({Desc.},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Dwg Ref.} = trim(replace(replace(replace(replace(replace(replace({Dwg Ref.},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Work Pack No.} = trim(replace(replace(replace(replace(replace(replace({Work Pack No.},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Work Pack Title} = trim(replace(replace(replace(replace(replace(replace({Work Pack Title},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Date Request} = trim(replace(replace(replace(replace(replace(replace({Date Request},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Date Inspect} = trim(replace(replace(replace(replace(replace(replace({Date Inspect},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Date Report} = trim(replace(replace(replace(replace(replace(replace({Date Report},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {QC RFI/IRN} = trim(replace(replace(replace(replace(replace(replace({QC RFI/IRN},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {PCM Status} = trim(replace(replace(replace(replace(replace(replace({PCM Status},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          Area = trim(replace(replace(replace(replace(replace(replace(Area,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          Stages = trim(replace(replace(replace(replace(replace(replace(Stages,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          Weightage = trim(replace(replace(replace(replace(replace(replace(Weightage,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          Status = trim(replace(replace(replace(replace(replace(replace(Status,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {Defect Category} = trim(replace(replace(replace(replace(replace(replace({Defect Category},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          Remarks = trim(replace(replace(replace(replace(replace(replace(Remarks,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {TRN NO} = trim(replace(replace(replace(replace(replace(replace({TRN NO},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          {IRN #} = trim(replace(replace(replace(replace(replace(replace({IRN #},'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          DATE = trim(replace(replace(replace(replace(replace(replace(DATE,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          Misc = trim(replace(replace(replace(replace(replace(replace(Misc,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\\\\',' '),'  ',' ')),",
				"          dc_function = split(split(dc_function,'_')[5],'.')[1],",
				"          File_Path = concat(trim(substringIndex(File_Path,'/',4),'/'),'/',substring(toString(currentTimestamp()),1,4),'/',substring(toString(currentTimestamp()),6,2),'/',substring(toString(currentTimestamp()),9,2),'/',replace(split(substringIndex(File_Path,'/',-1),'.')[1],'TEMP',''),'_',replace(replace(toString(currentTimestamp()),'.',''),':',''),'.csv')) ~> RemoveLineBreaks",
				"DCStage select(mapColumn(",
				"          {Project No},",
				"          Discipline,",
				"          Platform,",
				"          {Report No.},",
				"          {Platform Name},",
				"          {Report Number},",
				"          {Rev.},",
				"          {Desc.},",
				"          {Dwg Ref.},",
				"          {Work Pack No.},",
				"          {Work Pack Title},",
				"          {Date Request},",
				"          {Date Inspect},",
				"          {Date Report},",
				"          {QC RFI/IRN},",
				"          {PCM Status},",
				"          Area,",
				"          Stages,",
				"          Weightage,",
				"          Status,",
				"          {Defect Category},",
				"          Remarks,",
				"          {TRN NO},",
				"          {IRN #},",
				"          DATE,",
				"          Misc,",
				"          dc_function,",
				"          File_Path",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> SelectColumns",
				"RemoveLineBreaks derive(report_number_flag = iif(isNull({Report Number}) || trim({Report Number}) == '','false','true'),",
				"          rev_flag = iif(isNull({Rev.}) || trim({Rev.}) == '','false','true')) ~> FlagColumnsEmptyRows",
				"FlagColumnsEmptyRows filter(report_number_flag == 'true' || rev_flag == 'true') ~> FilterOutEmpyuRows",
				"FilterOutEmpyuRows select(mapColumn(",
				"          {Project No},",
				"          Discipline,",
				"          {Platform Name},",
				"          {Report Number},",
				"          {Rev.},",
				"          {Desc.},",
				"          {Dwg Ref.},",
				"          {Work Pack No.},",
				"          {Work Pack Title},",
				"          {Date Request},",
				"          {Date Inspect},",
				"          {Date Report},",
				"          {QC RFI/IRN},",
				"          {PCM Status},",
				"          Area,",
				"          Stages,",
				"          Weightage,",
				"          Status,",
				"          {Defect Category},",
				"          Remarks,",
				"          {TRN NO},",
				"          {IRN #},",
				"          DATE,",
				"          Misc,",
				"          dc_function,",
				"          File_Path",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectFinalColumns",
				"SelectFinalColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Column_1 as string,",
				"          Column_2 as string,",
				"          Column_3 as string,",
				"          Column_4 as string,",
				"          Column_5 as string,",
				"          Column_6 as string,",
				"          Column_7 as string,",
				"          Column_8 as string,",
				"          Column_9 as string,",
				"          Column_10 as string,",
				"          Column_11 as string,",
				"          Column_12 as string,",
				"          Column_13 as string,",
				"          Column_14 as string,",
				"          Column_15 as string,",
				"          Column_16 as string,",
				"          Column_17 as string,",
				"          Column_18 as string,",
				"          Column_19 as string,",
				"          Column_20 as string,",
				"          Column_21 as string,",
				"          Column_22 as string,",
				"          Column_23 as string,",
				"          Column_24 as string",
				"     ),",
				"     rowUrlColumn:'File_Path',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: []) ~> DCRaw"
			]
		}
	}
}