{
	"name": "df_yardkpi_r2p_stage_data_flattening",
	"properties": {
		"folder": {
			"name": "Projects/YARD KPI/R2P"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_xml_yardkpi_r2p_source",
						"type": "DatasetReference"
					},
					"name": "SrcXMl"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_yardkpi_r2p_generic",
						"type": "DatasetReference"
					},
					"name": "SnkCsv"
				}
			],
			"transformations": [
				{
					"name": "XmlToCsvflatten"
				},
				{
					"name": "addLoadDetails"
				}
			],
			"scriptLines": [
				"parameters{",
				"     csv_file_name as string,",
				"     source_name as string,",
				"     sub_source_name as string",
				"}",
				"source(output(",
				"          DATA_DS as (G_1 as (ACCOUNT_CODE_ITEM as string, AGREEMENT_NUMBER as string, BUYER as string, BUYER_EMAIL_ID as string, CATEGORY_ID as string, CURRENCY as string, END_DATE as string, FIRST_PO_VERSION_RECEIVE_DATE as string, FIRST_PO_VERSION_RECEIVE_DATE1 as string, FIRST_PO_VER_REC_DATE as string, INCOTERM as string, INIT_REV_LINE_AMT as string, LAST_UPDATE_DATE as string, MATERIAL_WORK_GROUP as string, MPP_PO as string, ORIGINALORDEREDAMOUNTDISPLAY as string, PAYMENT_MODE as string, PO_ACKNOWLEDGEMENT_DATE as string, PO_ACK_DATE_POV as string, PO_ACK_DATE_POV1 as string, PO_APPROVED_DATE as string, PO_APPROVER as string, PO_CLOSED_DATE as string, PO_CREATION_DATE as string, PO_DESCRIPTION as string, PO_NO as string, PO_REV as string, PO_REV_2 as string, PO_STATUS as string, PROJECT_ID as string, PROJECT_NAME as string, PURCHASER_REQUESTER as string, REQUESTER_EMAIL_ID as string, REQUISITION_BU as string, REQUISITION_DATE as string, REQUISITION_NO_ as string, REQUISITION_ORIGINATOR as string, REQ_RELEASED_TO_PROC as string, REVISED_DATE as string, SELECTION_CODE as string, SMAT_REV_NO as string, SOURCE_BASE_POH_ID as string, SOURCE_POH_ID as string, SPMAT_PO_NUMBER as string, START_DATE as string, SUPPLIER as string, SUPPLIER_COUNTRY as string, SUPPLIER_COUNTRY_CODE as string, SUPPLIER_LOCATION as string, SUPPLIER_NUM as string, SUPPLIER_TYPE as string, USD as string)[], PO_LAST_UPDATE_DATE_FROM as string, PO_LAST_UPDATE_DATE_TO as string)",
				"     ),",
				"     allowSchemaDrift: false,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     purgeFiles: true,",
				"     validationMode: 'none',",
				"     namespaces: true) ~> SrcXMl",
				"SrcXMl foldDown(unroll(DATA_DS.G_1),",
				"     mapColumn(",
				"          ACCOUNT_CODE_ITEM = DATA_DS.G_1.ACCOUNT_CODE_ITEM,",
				"          AGREEMENT_NUMBER = DATA_DS.G_1.AGREEMENT_NUMBER,",
				"          BUYER = DATA_DS.G_1.BUYER,",
				"          BUYER_EMAIL_ID = DATA_DS.G_1.BUYER_EMAIL_ID,",
				"          CATEGORY_ID = DATA_DS.G_1.CATEGORY_ID,",
				"          CURRENCY = DATA_DS.G_1.CURRENCY,",
				"          END_DATE = DATA_DS.G_1.END_DATE,",
				"          FIRST_PO_VERSION_RECEIVE_DATE = DATA_DS.G_1.FIRST_PO_VERSION_RECEIVE_DATE,",
				"          FIRST_PO_VERSION_RECEIVE_DATE1 = DATA_DS.G_1.FIRST_PO_VERSION_RECEIVE_DATE1,",
				"          FIRST_PO_VER_REC_DATE = DATA_DS.G_1.FIRST_PO_VER_REC_DATE,",
				"          INCOTERM = DATA_DS.G_1.INCOTERM,",
				"          INIT_REV_LINE_AMT = DATA_DS.G_1.INIT_REV_LINE_AMT,",
				"          LAST_UPDATE_DATE = DATA_DS.G_1.LAST_UPDATE_DATE,",
				"          MATERIAL_WORK_GROUP = DATA_DS.G_1.MATERIAL_WORK_GROUP,",
				"          MPP_PO = DATA_DS.G_1.MPP_PO,",
				"          ORIGINALORDEREDAMOUNTDISPLAY = DATA_DS.G_1.ORIGINALORDEREDAMOUNTDISPLAY,",
				"          PAYMENT_MODE = DATA_DS.G_1.PAYMENT_MODE,",
				"          PO_ACKNOWLEDGEMENT_DATE = DATA_DS.G_1.PO_ACKNOWLEDGEMENT_DATE,",
				"          PO_ACK_DATE_POV = DATA_DS.G_1.PO_ACK_DATE_POV,",
				"          PO_ACK_DATE_POV1 = DATA_DS.G_1.PO_ACK_DATE_POV1,",
				"          PO_APPROVED_DATE = DATA_DS.G_1.PO_APPROVED_DATE,",
				"          PO_APPROVER = DATA_DS.G_1.PO_APPROVER,",
				"          PO_CLOSED_DATE = DATA_DS.G_1.PO_CLOSED_DATE,",
				"          PO_CREATION_DATE = DATA_DS.G_1.PO_CREATION_DATE,",
				"          PO_DESCRIPTION = DATA_DS.G_1.PO_DESCRIPTION,",
				"          PO_NO = DATA_DS.G_1.PO_NO,",
				"          PO_REV = DATA_DS.G_1.PO_REV,",
				"          PO_REV_2 = DATA_DS.G_1.PO_REV_2,",
				"          PO_STATUS = DATA_DS.G_1.PO_STATUS,",
				"          PROJECT_ID = DATA_DS.G_1.PROJECT_ID,",
				"          PROJECT_NAME = DATA_DS.G_1.PROJECT_NAME,",
				"          PURCHASER_REQUESTER = DATA_DS.G_1.PURCHASER_REQUESTER,",
				"          REQUESTER_EMAIL_ID = DATA_DS.G_1.REQUESTER_EMAIL_ID,",
				"          REQUISITION_BU = DATA_DS.G_1.REQUISITION_BU,",
				"          REQUISITION_DATE = DATA_DS.G_1.REQUISITION_DATE,",
				"          REQUISITION_NO_ = DATA_DS.G_1.REQUISITION_NO_,",
				"          REQUISITION_ORIGINATOR = DATA_DS.G_1.REQUISITION_ORIGINATOR,",
				"          REQ_RELEASED_TO_PROC = DATA_DS.G_1.REQ_RELEASED_TO_PROC,",
				"          REVISED_DATE = DATA_DS.G_1.REVISED_DATE,",
				"          SELECTION_CODE = DATA_DS.G_1.SELECTION_CODE,",
				"          SMAT_REV_NO = DATA_DS.G_1.SMAT_REV_NO,",
				"          SOURCE_BASE_POH_ID = DATA_DS.G_1.SOURCE_BASE_POH_ID,",
				"          SOURCE_POH_ID = DATA_DS.G_1.SOURCE_POH_ID,",
				"          SPMAT_PO_NUMBER = DATA_DS.G_1.SPMAT_PO_NUMBER,",
				"          START_DATE = DATA_DS.G_1.START_DATE,",
				"          SUPPLIER = DATA_DS.G_1.SUPPLIER,",
				"          SUPPLIER_COUNTRY = DATA_DS.G_1.SUPPLIER_COUNTRY,",
				"          SUPPLIER_COUNTRY_CODE = DATA_DS.G_1.SUPPLIER_COUNTRY_CODE,",
				"          SUPPLIER_LOCATION = DATA_DS.G_1.SUPPLIER_LOCATION,",
				"          SUPPLIER_NUM = DATA_DS.G_1.SUPPLIER_NUM,",
				"          SUPPLIER_TYPE = DATA_DS.G_1.SUPPLIER_TYPE,",
				"          USD = DATA_DS.G_1.USD",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> XmlToCsvflatten",
				"XmlToCsvflatten derive(source_name = $source_name,",
				"          sub_source_name = $sub_source_name) ~> addLoadDetails",
				"addLoadDetails sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:[($csv_file_name)],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> SnkCsv"
			]
		}
	}
}