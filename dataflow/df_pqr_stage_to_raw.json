{
	"name": "df_pqr_stage_to_raw",
	"properties": {
		"folder": {
			"name": "Projects/YARD KPI/PQR"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_pqr_stg_generic",
						"type": "DatasetReference"
					},
					"name": "PQRStage"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gen2_pqr_raw_tgt",
						"type": "DatasetReference"
					},
					"name": "PCMRaw"
				}
			],
			"transformations": [
				{
					"name": "SetFileName"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Id as string,",
				"          ContentTypeID as string,",
				"          ContentType as string,",
				"          Title as string,",
				"          Modified as string,",
				"          Created as string,",
				"          CreatedById as string,",
				"          ModifiedById as string,",
				"          Owshiddenversion as string,",
				"          Version as string,",
				"          Path as string,",
				"          ComplianceAssetId as string,",
				"          SCOPE as string,",
				"          PROJECT as string,",
				"          PRIORITY as string,",
				"          WELDPOSITION as string,",
				"          CONSUMABLETRADENAMEAWSCLASS as string,",
				"          TESTMATERIALGRADE as string,",
				"          WELDPROCESS as string,",
				"          DIATHK as string,",
				"          WPSNo as string,",
				"          DeliveryOfMaterial as string,",
				"          CuttingBeveling as string,",
				"          WELDSTART as string,",
				"          WELDFINISH as string,",
				"          VISUAL as string,",
				"          PTMPI as string,",
				"          MUTAfterCooling48Hrs as string,",
				"          RT as string,",
				"          GougingGrindingRepair as string,",
				"          DateWeld1stRepair as string,",
				"          REMARK as string,",
				"          DPTMPI as string,",
				"          UT as string,",
				"          MUTRT as string,",
				"          PAUT as string,",
				"          SENDTOLAVORATORY as string,",
				"          PASSEDMECHANICALTESTING as string,",
				"          PQRPACKAGEAPPROVEDBYCLIENT as string,",
				"          CUTOFFDATE as string,",
				"          SRNo as string,",
				"          PROJECTCODEId as string,",
				"          CountApproved as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     multiLineRow: true) ~> PQRStage",
				"PQRStage derive(FileName = concat('Project_Data/YARDKPI/PQR/',substring(toString(currentTimestamp()),1,4),'/',substring(toString(currentTimestamp()),6,2),'/',substring(toString(currentTimestamp()),9,2),'/','STATUSWPSPQRQUALIFICATION_',replace(replace(toString(currentTimestamp()),'.',''),':',''),'.csv'),",
				"          source_code = 'SYSTEM',",
				"          sub_source_code = 'Sharepoint',",
				"          create_date_time = currentUTC()) ~> SetFileName",
				"SetFileName sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Id as string,",
				"          ContentTypeID as string,",
				"          ContentType as string,",
				"          Title as string,",
				"          Modified as string,",
				"          Created as string,",
				"          CreatedById as string,",
				"          ModifiedById as string,",
				"          Owshiddenversion as string,",
				"          Version as string,",
				"          Path as string,",
				"          ComplianceAssetId as string,",
				"          SCOPE as string,",
				"          PROJECT as string,",
				"          PRIORITY as string,",
				"          WELDPOSITION as string,",
				"          CONSUMABLETRADENAMEAWSCLASS as string,",
				"          TESTMATERIALGRADE as string,",
				"          WELDPROCESS as string,",
				"          DIATHK as string,",
				"          WPSNo as string,",
				"          DeliveryOfMaterial as string,",
				"          CuttingBeveling as string,",
				"          WELDSTART as string,",
				"          WELDFINISH as string,",
				"          VISUAL as string,",
				"          PTMPI as string,",
				"          MUTAfterCooling48Hrs as string,",
				"          RT as string,",
				"          GougingGrindingRepair as string,",
				"          DateWeld1stRepair as string,",
				"          REMARK as string,",
				"          DPTMPI as string,",
				"          UT as string,",
				"          MUTRT as string,",
				"          PAUT as string,",
				"          SENDTOLAVORATORY as string,",
				"          PASSEDMECHANICALTESTING as string,",
				"          PQRPACKAGEAPPROVEDBYCLIENT as string,",
				"          CUTOFFDATE as string,",
				"          SRNo as string,",
				"          PROJECTCODEId as string,",
				"          CountApproved as string,",
				"          source_code as string,",
				"          sub_source_code as string,",
				"          create_date_time as string",
				"     ),",
				"     rowUrlColumn:'FileName',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          each(match(true()))",
				"     )) ~> PCMRaw"
			]
		}
	}
}