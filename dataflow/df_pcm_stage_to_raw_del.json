{
	"name": "df_pcm_stage_to_raw_del",
	"properties": {
		"folder": {
			"name": "Projects/YARD KPI/PCM"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_weld_details_stg",
						"type": "DatasetReference"
					},
					"name": "PCMStage"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adlsg2_csv_yardkpi_pcm_default",
						"type": "DatasetReference"
					},
					"name": "PCMRaw"
				}
			],
			"transformations": [
				{
					"name": "SetFileName"
				}
			],
			"scriptLines": [
				"source(output(",
				"          trans_date as string,",
				"          trans_type as string,",
				"          fab_code as string,",
				"          contract as string,",
				"          contract_title as string,",
				"          job as string,",
				"          job_title as string,",
				"          item as string,",
				"          item_title as string,",
				"          ndt_drawing as string,",
				"          ndt_drawing_desc as string,",
				"          wctrl as string,",
				"          weld_suffix as string,",
				"          stress_relief as string,",
				"          weld_repair_ref as string,",
				"          discipline as string,",
				"          spool as string,",
				"          weld as string,",
				"          weld_location as string,",
				"          weld_type as string,",
				"          joint_type as string,",
				"          material_type as string,",
				"          material_grade as string,",
				"          material_type2 as string,",
				"          material_grade2 as string,",
				"          fabrication_area as string,",
				"          weld_attachment as string,",
				"          weld_category as string,",
				"          pipe_bore as string,",
				"          pipe_schedule as string,",
				"          thickness as string,",
				"          diameter as string,",
				"          weld_length as string,",
				"          weld_date as string,",
				"          weld_status as string,",
				"          weld_clear_date as string,",
				"          cutout as string,",
				"          weldcount as string,",
				"          weld_updated_on as string,",
				"          recap as string,",
				"          repair_gen as string,",
				"          repair_status_code as string,",
				"          weld_repair_date as string,",
				"          mcd_inspector as string,",
				"          client_inspector as string,",
				"          vis_report_num as string,",
				"          vis_date as string,",
				"          clear_date as string,",
				"          weld_machine as string,",
				"          fitter1 as string,",
				"          fitter2 as string,",
				"          fitter3 as string,",
				"          Fitup_insp_name as string,",
				"          fitup_date as string,",
				"          fitup_status as string,",
				"          fitup_updated_on as string,",
				"          fitup_inspection_date as string,",
				"          fitup_inspector as string,",
				"          fitup_rep_num as string,",
				"          mtn1 as string,",
				"          mtn2 as string,",
				"          include_in_rr_calc as string,",
				"          fitter_leader_man as string,",
				"          leaderman_badgeid as string,",
				"          leaderman_name as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     purgeFiles: true,",
				"     multiLineRow: true,",
				"     wildcardPaths:['Project_Data/YARDKPI/PCM_Del/pcm_weld_details_del*.csv']) ~> PCMStage",
				"PCMStage derive(FileName = concat('Project_Data/YARDKPI/PCM_Del/',substring(toString(currentTimestamp()),1,4),'/',substring(toString(currentTimestamp()),6,2),'/',substring(toString(currentTimestamp()),9,2),'/','PCM_WELD_DETAILS_DEL_',replace(replace(toString(currentTimestamp()),'.',''),':',''),'.csv'),",
				"          create_date_time = currentUTC(),",
				"          ndt_drawing_desc = regexReplace(regexReplace(replace(replace(replace(replace(replace(replace(ndt_drawing_desc,' ',''),'\\\\n',''),'\\\\r',''),'CHAR(10)',''),'\"',''),'CHAR(13)',''),'\\n',''),'\\r',''),",
				"          ndt_drawing = trim(replace(replace(replace(replace(replace(replace(replace(ndt_drawing,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\"',' '),'\\\\',' '),'  ',' ')),",
				"          contract_title = trim(replace(replace(replace(replace(replace(replace(replace(contract_title,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\"',' '),'\\\\',' '),'  ',' ')),",
				"          job_title = trim(replace(replace(replace(replace(replace(replace(replace(job_title,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\"',' '),'\\\\',' '),'  ',' ')),",
				"          item_title = trim(replace(replace(replace(replace(replace(replace(replace(item_title,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\"',' '),'\\\\',' '),'  ',' ')),",
				"          weld_category = trim(replace(replace(replace(replace(replace(replace(replace(weld_category,'\\n',' '),'\\r',' '),'\\r\\n',' '),',',' '),'\"',' '),'\\\\',' '),'  ',' '))) ~> SetFileName",
				"SetFileName sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     rowUrlColumn:'FileName',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          each(match(true()))",
				"     )) ~> PCMRaw"
			]
		}
	}
}