													"text": "update [epr].[Weekly_progress_summary_L2_Ruya11_D7507_Stage] \nset current_cuttoff = b.Prop_3\nfrom [epr].[Weekly_progress_summary_L2_Ruya11_D7507_Stage] a,\n(select * from [epr].[Weekly_progress_summary_L2_Ruya11_D7507_Stage]\n where Prop_2 = 'Cut off :') b\n where a.file_name = b.file_name ;\n\nupdate [epr].[Weekly_progress_summary_L2_Ruya11_D7507_Stage] \nset previous_cuttoff = FORMAT(dateadd(d,-7,cast(current_cuttoff as datetime)),'yyyy-MM-dd','en-US') ;\n\ndelete from [epr].[Weekly_progress_summary_L2_Ruya11_D7507_Stage]  where isnull(Prop_0,'') = '' ;\n\ndelete from [epr].[Weekly_progress_summary_L2_Ruya11_D7507_Stage]  where isnull(Prop_0,'') = 'S.No' ;\n\ndelete from [epr].[Weekly_progress_summary_L2_Ruya11_D7507_Stage]  where isnull(Prop_0,'') = 'Level-II Progress Summary' ;\n\nupdate [epr].[Weekly_progress_summary_L2_Ruya11_D7507_Stage] set \n\t[S.No] = Prop_0,\n\t[Description] = Prop_1,\n\t[Overall W.F L1] = Prop_2,\n\t[Overall W.F L2] = Prop_3,\n\t[Weekly_Plan] = Prop_4,\n\t[Weekly_Forecast Plan] = Prop_5,\n\t[Weekly_Actual] = Prop_6,\n\t[Weekly_Plan Var.] = Prop_7,\n\t[Weekly_Forecast var.] = Prop_8,\n\t[Cumulative_Plan] = Prop_9,\n\t[Cumulative_Forecast Plan] = Prop_10,\n\t[Cumulative_Actual] = Prop_11,\n\t[Cumulative_Plan Var.] = Prop_12,\n\t[Cumulative_Forecast var.] = Prop_13,\n\t[Delay Justification] = Prop_14,\n\t[Previous_week_Plan] = Prop_16,\n\t[Previous_week_Forecast Plan] = Prop_17,\n\t[Previous_week_Actual] = Prop_18,\n\t[Previous_week_Plan Var.] = Prop_19\n"
