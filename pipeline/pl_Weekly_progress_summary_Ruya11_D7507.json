											"scripts": [
												{
													"type": "Query",
													"text": "update [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage] \nset current_cuttoff = b.Prop_4\nfrom [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage] a,\n(select * from [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage]\n where Prop_3 = 'Cut off :') b\n where a.file_name = b.file_name ;\n\nupdate [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage] \nset previous_cuttoff = b.Prop_17\nfrom [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage] a,\n(select * from [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage]\n where Prop_15 = 'Cut off :') b\n where a.file_name = b.file_name ;\n\n update [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage] \nset [S.No] = Prop_0,\n\t[Description] = Prop_1,\n\t[Overall W.F] = Prop_2,\n\t[Weekly_Plan] = Prop_4,\n\t[Weekly_Forecast Plan] = Prop_5,\n\t[Weekly_Actual]  = Prop_6,\n\t[Weekly_Plan Var.] = Prop_7 ,\n\t[Weekly_Forecast var.] = Prop_8 ,\n\t[Cumulative_Plan] = Prop_9,\n\t[Cumulative_Forecast Plan] = Prop_10,\n\t[Cumulative_Actual] = Prop_11,\n\t[Cumulative_Plan Var.] = Prop_12,\n\t[Cumulative_Forecast var.] = Prop_13,\n\t[Previous_week_Plan] = Prop_15,\n\t[Previous_week_Forecast Plan] = Prop_16,\n\t[Previous_week_Actual] = Prop_17,\n\t[Previous_week_Plan Var.] = Prop_18,\n\t[Previous_week_Forecast var.] = Prop_19  ;\n\n\tdelete from [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage] where isnull(Prop_0,'') = ''  ;\n\n\tdelete from [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage] where isnull(Prop_0,'') = 'S.No'  ;\n\n\tdelete from [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage] where isnull(Prop_0,'') = 'Level-I Progress Summary'  ;\n\n\tupdate [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage] set [Description] = [S.No] where [S.No] = 'OVERALL PROJECT'  ;\n\n\tupdate [epr].[Weekly_progress_summary_L1_Ruya11_D7507_Stage] set [S.No] = 'Total' where [Description] = 'OVERALL PROJECT'  ;\n"
