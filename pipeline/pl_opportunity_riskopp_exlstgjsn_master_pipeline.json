								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "SqlDWSource",
									"sqlReaderStoredProcedureName": "[dbo].[get_PMR_Email_details]",
									"storedProcedureParameters": {
										"load_name": {
											"type": "String",
											"value": {
												"value": "@activity('lk_get_pipeline_parameters_2').output.firstRow.load_name",
