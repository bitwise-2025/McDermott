										"type": "DelimitedTextReadSettings"
									}
								},
								"dataset": {
									"referenceName": "ds_adlsg2_csv_generic_File_StageJSON",
									"type": "DatasetReference",
									"parameters": {
										"p_ds_filename": {
											"value": "@concat('Initial_',activity('lk_get_pipeline_parameters_2').output.firstRow.file_name,'.csv')",
											"type": "Expression"
										},
										"p_ds_folder": {
											"value": "@activity('lk_get_pipeline_parameters_2').output.firstRow.folder_path",
											"type": "Expression"
										}
									}
								}
							}
						},
						{
							"name": "LookupEmailStats",
							"type": "Lookup",
