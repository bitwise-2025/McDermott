								"source": {
									"type": "ExcelSource",
									"additionalColumns": [
										{
											"name": "zSourceFileName",
											"value": "$$FILEPATH"
										},
										{
											"name": "zCreatedDateTime",
											"value": {
												"value": "@activity('lk_get_pipeline_parameters_2').output.firstRow.run_start_datetime",
												"type": "Expression"
											}
										},
										{
											"name": "zVersionNo",
											"value": {
												"value": "@{add(int(activity('lk_get_pipeline_parameters_2').output.firstRow.version_no),1)}",
												"type": "Expression"
											}
										}
									],
									"storeSettings": {
										"type": "FileServerReadSettings",
										"recursive": true,
										"modifiedDatetimeStart": {
											"value": "@activity('lk_get_pipeline_parameters_2').output.firstRow.start_date",
											"type": "Expression"
										},
										"wildcardFileName": "*.xlsx"
									}
								},
								"sink": {
									"type": "DelimitedTextSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings",
										"copyBehavior": "MergeFiles"
									},
									"formatSettings": {
										"type": "DelimitedTextWriteSettings",
										"quoteAllText": true,
										"fileExtension": ".txt"
