									"type": "Expression"
								},
								"ifTrueActivities": [
									{
										"name": "Send Email On Success",
										"type": "WebActivity",
										"dependsOn": [],
										"policy": {
											"timeout": "0.12:00:00",
											"retry": 0,
											"retryIntervalInSeconds": 30,
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"method": "POST",
											"headers": {
												"Content-Type": "application/json"
											},
											"url": {
												"value": "@activity('lk_get_pipeline_parameters_2').output.firstRow.logicapp_url",
												"type": "Expression"
											},
											"body": {
												"value": "{\n    \"DataFactoryName\": \"@{pipeline().DataFactory}\",\n    \"PipelineName\": \"@{pipeline().Pipeline}\",\n    \"Activity\": \"MANUAL Excel Uploads\",\n    \"ProjectNo\": \"@{activity('LookupEmailStats').output.firstRow.project_no}\",\n    \"FileName\": \"@{activity('LookupEmailStats').output.firstRow.file_name}\",\n    \"LoadName\": \"@{activity('LookupEmailStats').output.firstRow.load_name}\",\n    \"ProcessedRecordCount\": \"@{activity('LookupEmailStats').output.firstRow.processed_record_count}\",\n    \"ErrorRecordCount\": \"@{activity('LookupEmailStats').output.firstRow.error_record_count}\",\n\t\"EmailTo\": \"@{activity('LookupEmailStats').output.firstRow.email_id}\",\n\t\"VersionNo\": \"@{activity('LookupEmailStats').output.firstRow.version_no}\"\n}",
												"type": "Expression"
											}
										}
									}
								]
							}
						}
					]
				}
			},
			{
				"name": "lk_get_pipeline_parameters",
				"description": "Get the parameters to be used in this pipeline",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderStoredProcedureName": "getPipelineParametersValues",
						"storedProcedureParameters": {
							"pPipelineCode": {
								"type": "String",
								"value": "pl_ncsa_master_pipelines"
							},
							"pPipeLineSubCode": {
								"type": "String",
								"value": "EMAIL"
							}
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
