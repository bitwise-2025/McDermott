						{
							"name": "INSERT_ADFExtFileLogs",
							"description": "INSERT an entry into the log table [dbo].[ADFExtFileLogs] for every file process successfully.",
							"type": "Script",
							"dependsOn": [
								{
									"activity": "cp_archive_fs_file",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "7.00:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"linkedServiceName": {
								"referenceName": "AzureSynapseDB_DEV",
								"type": "LinkedServiceReference"
							},
							"typeProperties": {
								"scripts": [
									{
										"type": "Query",
										"text": {
											"value": "@concat('INSERT INTO [dbo].[ADFExtFileLogs]  ([PipelineName]  ,[RunId]  ,[ExternalFilename]  ,[VersionNo]  ,[Archive_location]  ,[Uploaded_by]  ,[SourceRecords]  ,[CreatedDateTime]) ',\n' SELECT ''',pipeline().Pipeline,''' as PipelineName, ''',pipeline().RunId,''' as RunId, ''',item().name,''' as SrcFileName,'''\n,string(add(int(activity('lk_get_pipeline_parameters_2').output.firstRow.version_no),1)),''' as VersionNo, '''\n,concat(activity('lk_get_pipeline_parameters_2').output.firstRow.folder_path,'/',formatDateTime(utcnow(),'yyyy'),'/',formatDateTime(utcnow(),'MM'),'/',formatDateTime(utcnow(),'dd'),'/','VersionNo-',string(add(int(activity('lk_get_pipeline_parameters_2').output.firstRow.version_no),1)), '_', formatDateTime(utcnow(),'yyyy-MM-dd THHmmss'),'_', item().name),''' as Archive\n, NULL as UploadedBy,''', activity('cp_copy_from_network_to_blob').output.rowsRead ,'''as RecordCount,''',activity('lk_get_pipeline_parameters_2').output.firstRow.run_start_datetime,''' as CreatedDateTime')",
											"type": "Expression"
										}
									}
								]
							}
						},
