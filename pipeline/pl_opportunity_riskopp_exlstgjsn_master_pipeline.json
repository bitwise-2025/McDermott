									"referenceName": "ds_filesystem_network_excel_get_subfolders_ncsa",
									"type": "DatasetReference",
									"parameters": {
										"path": {
											"value": "@concat(activity('lk_get_pipeline_parameters_2').output.firstRow.source_directory,'/',item().name)",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_adlsg2_csv_generic_File_StageJSON",
									"type": "DatasetReference",
									"parameters": {
										"p_ds_filename": {
											"value": "@concat('Initial_',activity('lk_get_pipeline_parameters_2').output.firstRow.file_name,'.csv')",
											"type": "Expression"
										},
										"p_ds_folder": {
											"value": "@activity('lk_get_pipeline_parameters_2').output.firstRow.folder_path",
											"type": "Expression"
										}
									}
								}
							]
						},
						{
