{
	"name": "pl_yardkpi_idocs_ms_master_fab_source_to_stage",
	"properties": {
		"activities": [
			{
				"name": "lk_get_pipeline_parameters",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderStoredProcedureName": "getPipelineParametersValues",
						"storedProcedureParameters": {
							"pPipelineCode": {
								"type": "String",
								"value": {
									"value": "@pipeline().Pipeline",
									"type": "Expression"
								}
							},
							"pPipeLineSubCode": {
								"type": "String",
								"value": {
									"value": "iDocs",
									"type": "Expression"
								}
							}
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_azure_synapse_parameter",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "Get Project Directory Names",
				"type": "GetMetadata",
				"dependsOn": [
					{
						"activity": "lk_get_pipeline_parameters",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_fs_csv_yardkpi_idocs_source_generic",
						"type": "DatasetReference",
						"parameters": {
							"directory": {
								"value": "@coalesce('')",
								"type": "Expression"
							},
							"file": {
								"value": "@coalesce('')",
								"type": "Expression"
							}
						}
					},
					"fieldList": [
						"childItems",
						"itemName",
						"itemType"
					],
					"storeSettings": {
						"type": "FileServerReadSettings",
						"recursive": true
					},
					"formatSettings": {
						"type": "DelimitedTextReadSettings"
					}
				}
			},
			{
				"name": "Filter Project Directory Names",
				"description": "Check for project folders with proper naming convention",
				"type": "Filter",
				"dependsOn": [
					{
						"activity": "Get Project Directory Names",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('Get Project Directory Names').output.childItems",
						"type": "Expression"
					},
					"condition": {
						"value": "@and(startswith(item().name,activity('lk_get_pipeline_parameters').output.firstRow.input_folder_path),equals(item().type,'Folder'))",
						"type": "Expression"
					}
				}
			},
			{
				"name": "ForEach IDOCS Project Directory",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "Filter Project Directory Names",
						"dependencyConditions": [
							"Succeeded"
						]
					},
					{
						"activity": "Set last_run_start_date",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('Filter Project Directory Names').output.Value",
						"type": "Expression"
					},
					"isSequential": false,
					"activities": [
						{
							"name": "Get Flle Names",
							"type": "GetMetadata",
							"dependsOn": [],
							"policy": {
								"timeout": "7.00:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataset": {
									"referenceName": "ds_fs_csv_yardkpi_idocs_source_generic",
									"type": "DatasetReference",
									"parameters": {
										"directory": {
											"value": "@item().name",
											"type": "Expression"
										},
										"file": {
											"value": "@coalesce('')",
											"type": "Expression"
										}
									}
								},
								"fieldList": [
									"childItems",
									"itemName",
									"itemType"
								],
								"storeSettings": {
									"type": "FileServerReadSettings",
									"recursive": true,
									"modifiedDatetimeStart": {
										"value": "@activity('lk_get_pipeline_parameters').output.firstRow.last_run_start_date",
										"type": "Expression"
									}
								},
								"formatSettings": {
									"type": "DelimitedTextReadSettings"
								}
							}
						},
						{
							"name": "Filter File Name",
							"description": "Check for project folders with proper naming convention",
							"type": "Filter",
							"dependsOn": [
								{
									"activity": "Get Flle Names",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"userProperties": [],
							"typeProperties": {
								"items": {
									"value": "@activity('Get Flle Names').output.childItems",
									"type": "Expression"
								},
								"condition": {
									"value": "@and(and(endswith(item().name,'.CSV'),equals(item().type,'File')),contains(item().name,activity('lk_get_pipeline_parameters').output.firstRow.input_file_name))",
									"type": "Expression"
								}
							}
						},
						{
							"name": "iDocs Files Extracting from Sorce",
							"type": "ExecutePipeline",
							"dependsOn": [
								{
									"activity": "Filter File Name",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "pl_yardkpi_idocs_ms_master_fab_source_file_extract",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true,
								"parameters": {
									"filtered_file_list": {
										"value": "@activity('Filter File Name').output.value",
										"type": "Expression"
									},
									"source_directory": {
										"value": "@item().name",
										"type": "Expression"
									},
									"stage_file_system": {
										"value": "@activity('lk_get_pipeline_parameters').output.firstRow.file_system",
										"type": "Expression"
									},
									"stage_folder_path": {
										"value": "@activity('lk_get_pipeline_parameters').output.firstRow.folder_path",
										"type": "Expression"
									}
								}
							}
						}
					]
				}
			},
			{
				"name": "Set last_run_start_date",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "Filter Project Directory Names",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
