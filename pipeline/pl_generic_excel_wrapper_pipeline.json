{
	"name": "pl_generic_excel_wrapper_pipeline",
	"properties": {
		"description": "Wrapper Pipeline to run the SRC->STG-->RAW--> SYNSTG pipelines in proper sequence.",
		"activities": [
			{
				"name": "Source to Stage",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "val_Check_SourceFile_Availablity",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "pl_generic_excel_source_to_stage",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"p_pl_pipelineCode": {
							"value": "@pipeline().parameters.p_plw_pipelineCode",
							"type": "Expression"
						},
						"p_pl_pipelineSubCode": {
							"value": "@pipeline().parameters.p_plw_pipelineSubCode",
							"type": "Expression"
						}
					}
				}
			},
			{
				"name": "Stage to Raw",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "Source to Stage",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "pl_generic_excel_stage_raw",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"p_pl_pipelineCode": {
							"value": "@pipeline().parameters.p_plw_pipelineCode",
							"type": "Expression"
						},
						"p_pl_pipelineSubCode": {
							"value": "@pipeline().parameters.p_plw_pipelineSubCode",
							"type": "Expression"
						}
					}
				}
			},
			{
				"name": "Raw to SynStg",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "Stage to Raw",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "pl_generic_excel_raw_to_syn_stg",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"p_pl_pipelineCode": {
							"value": "@pipeline().parameters.p_plw_pipelineCode",
							"type": "Expression"
						},
						"p_pl_pipelineSubCode": {
							"value": "@pipeline().parameters.p_plw_pipelineSubCode",
							"type": "Expression"
						}
					}
				}
			},
			{
				"name": "lk_get_pipeline_parameters",
				"description": "Get the parameters to be used in this pipeline",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.01:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderStoredProcedureName": "getPipelineParametersValues",
						"storedProcedureParameters": {
							"pPipelineCode": {
								"type": "String",
								"value": "pl_ncsa_master_pipelines"
							},
							"pPipeLineSubCode": {
								"type": "String",
								"value": "EMAIL"
							}
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_azure_synapse_parameter",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "Append SRC to STG Error",
				"type": "AppendVariable",
				"dependsOn": [
					{
						"activity": "Source to Stage",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"variableName": "v_error_message",
					"value": {
						"value": "@concat('Source to Stage Failure: ',\nactivity('Source To Stage').error.message,'. Pipeline Parameters [',pipeline().parameters.p_plw_pipelineCode,' ; ',pipeline().parameters.p_plw_pipelineSubCode,']|',\nactivity('Source To Stage').output.pipelineName,'|',\nactivity('Source To Stage').output.pipelineRunId,'|')",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Append STG to RAW Error",
				"type": "AppendVariable",
				"dependsOn": [
					{
						"activity": "Stage to Raw",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"variableName": "v_error_message",
					"value": {
						"value": "@concat('Stage to Raw Failure: ',\nactivity('Stage to Raw').error.message ,'. Pipeline Parameters [',pipeline().parameters.p_plw_pipelineCode,' ; ',pipeline().parameters.p_plw_pipelineSubCode,']|',\nactivity('Stage to Raw').output.pipelineName,'|',\nactivity('Stage to Raw').output.pipelineRunId,'|')",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Append RAW to SYNSTG",
				"type": "AppendVariable",
				"dependsOn": [
					{
						"activity": "Raw to SynStg",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"variableName": "v_error_message",
					"value": {
						"value": "@concat('Raw to SynapseSTG Failure: ',\nactivity('Raw to SynStg').error.message ,'. Pipeline Parameters [',pipeline().parameters.p_plw_pipelineCode,' ; ',pipeline().parameters.p_plw_pipelineSubCode,']|',\nactivity('Raw to SynStg').output.pipelineName,'|',\nactivity('Raw to SynStg').output.pipelineRunId,'|')\n",
						"type": "Expression"
					}
				}
			},
			{
				"name": "ADF_Log",
				"description": "SPU to log the details of the Pipeline run",
				"type": "SqlServerStoredProcedure",
				"dependsOn": [
					{
						"activity": "Raw to SynStg",
						"dependencyConditions": [
							"Completed",
							"Skipped"
						]
					},
					{
						"activity": "Append RAW to SYNSTG",
						"dependencyConditions": [
							"Completed",
							"Skipped"
						]
					}
				],
				"policy": {
					"timeout": "1.00:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"storedProcedureName": "[dbo].[usp_InsertADFLogs]",
					"storedProcedureParameters": {
						"DataFactoryName": {
							"value": {
								"value": "@pipeline().DataFactory",
								"type": "Expression"
							},
							"type": "String"
						},
						"Error_pipeline_name": {
							"value": {
								"value": "@if(empty(variables('v_error_message')),\nif( not(empty(activity('val_Check_SourceFile_Availablity').output.childItems)),\nconcat(activity('Source To Stage').output.pipelineName,';',\nactivity('Stage to Raw').output.pipelineName,';',\nactivity('Raw to SynStg').output.pipelineName)\n,NULL)\n,split(join(variables('v_error_message'),';'),'|' )[1])",
								"type": "Expression"
							},
							"type": "String"
						},
						"Error_pipeline_runid": {
							"value": {
								"value": "@if(empty(variables('v_error_message')),NULL,split(join(variables('v_error_message'),';'),'|' )[2])",
								"type": "Expression"
							},
							"type": "String"
						},
						"ErrorMessage": {
							"value": {
								"value": "@if(empty(variables('v_error_message')),\nif( empty(activity('val_Check_SourceFile_Availablity').output.childItems),\n'Source file unavailable for the current run'\n,NULL)\n,split(join(variables('v_error_message'),';'),'|' )[0])",
								"type": "Expression"
							},
							"type": "String"
						},
						"PipelineName": {
							"value": {
								"value": "@pipeline().parameters.p_plw_pipelineCode",
								"type": "Expression"
							},
							"type": "String"
						},
						"runid": {
							"value": {
								"value": "@pipeline().RunId",
								"type": "Expression"
							},
							"type": "String"
						},
						"status": {
							"value": {
								"value": "@if(empty(variables('v_error_message')),'Success','Failed')",
								"type": "Expression"
							},
							"type": "String"
						}
					}
				},
				"linkedServiceName": {
					"referenceName": "Azure_Dev_SynapseAnalyticsPool",
					"type": "LinkedServiceReference"
				}
			},
			{
				"name": "If failure detected send mail",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "ADF_Log",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@if(empty(variables('v_error_message')),false,true)",
						"type": "Expression"
					},
					"ifTrueActivities": [
						{
							"name": "Send Email On Failure",
							"type": "WebActivity",
							"dependsOn": [],
							"policy": {
								"timeout": "1.00:00:00",
								"retry": 1,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"method": "POST",
								"headers": {
									"Content-Type": "application/json"
								},
								"url": "https://prod-31.eastus.logic.azure.com:443/workflows/03d7da5abbab4215a05aeaceae3b96fa/triggers/manual/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=asuyutHtoSxGFURsj1-A6AKRiNLdXZ4mTnZvZ17_8hI",
								"connectVia": {
									"referenceName": "integrationRuntimeEast2",
									"type": "IntegrationRuntimeReference"
								},
								"body": {
									"value": "{\n    \"DataFactoryName\": \"@{pipeline().DataFactory}\",\n    \"PipelineName\": \"@{concat(pipeline().Pipeline,' run for ',pipeline().parameters.p_plw_pipelineCode)}\",\n    \"ErrorMessage\": \"@{replace(replace(join(variables('v_error_message'),';'),'\"',''),'\\','/')}\",\n\"EmailTo\": \"@{activity('lk_get_pipeline_parameters').output.firstRow.ncsa_master_pipeline_email_to}\",\n    \"Activity\":  \"@{if(empty(variables('v_error_message')),'',split(join(variables('v_error_message'),';'),'|' )[1])}\"\n}",
									"type": "Expression"
								}
							}
						}
					]
				}
			},
			{
				"name": "lk_get_pipeline_parameters_2",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.01:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderStoredProcedureName": "getPipelineParametersValues",
						"storedProcedureParameters": {
							"pPipelineCode": {
								"type": "String",
								"value": {
									"value": "@pipeline().parameters.p_plw_pipelineCode",
									"type": "Expression"
								}
							},
							"pPipeLineSubCode": {
								"type": "String",
								"value": {
									"value": "@pipeline().parameters.p_plw_pipelineSubCode",
									"type": "Expression"
								}
							}
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_azure_synapse_parameter",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "val_Check_SourceFile_Availablity",
				"description": "Check if the source file is available at the Dataset location. If not wait for the timeout period.",
				"type": "Validation",
				"dependsOn": [
					{
						"activity": "lk_get_pipeline_parameters_2",
						"dependencyConditions": [
							"Succeeded"
						]
					},
					{
						"activity": "lk_get_pipeline_parameters",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_fs_excel_weeklyplan_source",
						"type": "DatasetReference",
						"parameters": {
							"Path": {
								"value": "@activity('lk_get_pipeline_parameters_2').output.firstRow.source_directory",
								"type": "Expression"
							},
							"File": {
								"value": "@activity('lk_get_pipeline_parameters_2').output.firstRow.input_file_name",
								"type": "Expression"
							}
						}
					},
					"timeout": "0.00:02:00",
					"sleep": 50,
					"childItems": true
				}
			}
		],
		"parameters": {
			"p_plw_pipelineCode": {
				"type": "string"
			},
			"p_plw_pipelineSubCode": {
				"type": "string",
				"defaultValue": "NetworkFolder"
			}
		},
		"variables": {
			"v_error_message": {
				"type": "Array"
			}
		},
		"folder": {
			"name": "Projects/NCSA/Generic Reuse Pipeline"
		},
		"annotations": [],
		"lastPublishTime": "2022-05-11T05:42:19Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}