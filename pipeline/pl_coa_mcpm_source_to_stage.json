{
	"name": "pl_coa_mcpm_source_to_stage",
	"properties": {
		"activities": [
			{
				"name": "cp_getCoAMCPMdata",
				"description": "The source query contains two queries for database pims_onshore and pims_offshore to get data from both database.",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "lk_get_pipeline_parameters",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlServerSource",
						"sqlReaderQuery": {
							"value": "@concat('select Domain\n\n,CoA\n\n,Coa_Title\n\n,CostCode\n\n,CostCode_Title\n\n,CostType\n\n,SCT\n\n,WBS\n\n,WBS_Title\n\n,WBSLevel2\n\n,WBSLevel2_Title\n\n,WBSLevel3\n\n,WBSLevel3_Title\n\n,WBSLevel4\n\n,WBSLevel4_Title\n\n,KeyUoMImperial\n\n,KeyUoMMetric\n\n,PSRLevel1\n\n,PSRLevel2\n\n,PSRLevel1_Title\n\n,PSRLevel2_Title\n\n,Phase\n\n,Phase_Title\n\n,domain_code_ct\n\n,''Onshore'' as Source\n\n from aviw_ProjectSetup_Tableau_CoA_PSR\n\nwhere ' , '''',  activity('lk_get_pipeline_parameters').output.firstRow.project,'''','like ','''','%','''',' + domain + ','''','%',''''\n\n,' Union\n\n select Domain\n\n,CoA\n\n,Coa_Title\n\n,CostCode\n\n,CostCode_Title\n\n,CostType\n\n,SCT\n\n,WBS\n\n,WBS_Title\n\n,WBSLevel2\n\n,WBSLevel2_Title\n\n,WBSLevel3\n\n,WBSLevel3_Title\n\n,WBSLevel4\n\n,WBSLevel4_Title\n\n,KeyUoMImperial\n\n,KeyUoMMetric\n\n,PSRLevel1\n\n,PSRLevel2\n\n,PSRLevel1_Title\n\n,PSRLevel2_Title\n\n,Phase\n\n,Phase_Title\n\n,domain_code_ct,''Offshore'' as Source from [aviw_ProjectSetup_Tableau_CoA_PSR]\n\nwhere ' , '''',  activity('lk_get_pipeline_parameters').output.firstRow.project,'''','like ','''','%','''',' + domain + ','''','%',''''\n\n)",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_mcpm_onshore_prod",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "ds_adlsg2_csv_generic_mcpm_coa",
						"type": "DatasetReference",
						"parameters": {
							"p_ds_filesystem": {
								"value": "@activity('lk_get_pipeline_parameters').output.firstRow.file_system",
								"type": "Expression"
							},
							"p_ds_directory": {
								"value": "@activity('lk_get_pipeline_parameters').output.firstRow.folder_path",
								"type": "Expression"
							},
							"p_ds_filename": {
								"value": "@concat(activity('lk_get_pipeline_parameters').output.firstRow.file_name,'.csv')",
								"type": "Expression"
							},
							"p_ds_first_row_header": true
						}
					}
				]
			},
			{
				"name": "lk_get_pipeline_parameters",
				"description": "Use the lookup procedure to get the last run details to be used in the next steps",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderStoredProcedureName": "getPipelineParametersValues",
						"storedProcedureParameters": {
							"pPipelineCode": {
								"type": "String",
								"value": {
									"value": "@pipeline().Pipeline",
									"type": "Expression"
								}
							},
							"pPipeLineSubCode": {
								"type": "String",
								"value": "MCPM"
							}
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_azure_synapse_parameter",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "sp_Update_Parameter",
				"description": "Update the appropriate parameter in the parameter table",
				"type": "SqlServerStoredProcedure",
				"dependsOn": [
					{
						"activity": "cp_getCoAMCPMdata",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"storedProcedureName": "[dbo].[updateIncrementPipelineParameterValue]",
					"storedProcedureParameters": {
						"pParameterValue": {
							"value": {
								"value": "@formatDateTime(activity('lk_get_pipeline_parameters').output.firstRow.run_start_datetime,'yyyy-MM-dd HH:mm:ss')",
								"type": "Expression"
							},
							"type": "String"
						},
						"pPipelineCode": {
							"value": {
								"value": "@pipeline().Pipeline",
								"type": "Expression"
							},
							"type": "String"
						},
						"pPipelineSubCode": {
							"value": "MCPM",
							"type": "String"
						},
						"pParameterCode": {
							"value": "start_date",
							"type": "String"
						}
					}
				},
				"linkedServiceName": {
					"referenceName": "Azure_Dev_SynapseAnalyticsPool",
					"type": "LinkedServiceReference"
				}
			}
		],
		"variables": {
			"v_run_start": {
				"type": "String"
			}
		},
		"folder": {
			"name": "Projects/NCSA/20. CoA"
		},
		"annotations": [],
		"lastPublishTime": "2023-11-17T05:35:50Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}