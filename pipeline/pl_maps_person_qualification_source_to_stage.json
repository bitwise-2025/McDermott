{
	"name": "pl_maps_person_qualification_source_to_stage",
	"properties": {
		"activities": [
			{
				"name": "cp_get_maps_person_qualification",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "lk_get_pipeline_parameters",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlServerSource",
						"sqlReaderQuery": {
							"value": "select a.*,b.Requirement_Name as Mandatory from ql_Person_Qualification a,\n (Select pers.Id_Number,\n\t\t\t\t\trqc.ql_Qualification_Id\n\t\t\t\t\t,rqp.Requirement_Name\n \n \n\tFrom Person pers\n\tLeft Join Posting posti on pers.Id_Number=posti.Id_Number\n        Left Join Grade g on g.Grade_sht_Title=pers.Grade_sht_Title \n\tLeft Join Post on posti.Post_Id=Post.Post_Id\n \n\t\n\tjoin Role on g.Spare_Char_1_255 =Role.Role_id\n\tJoin  ql_Requirement_Structure rqp on rqp.Parent_Key=Role.Role_id\n\tLeft Join ql_Requirement_Structure rqc on rqp.ql_req_struct_Id = rqc.Parent_ql_struct_Id\n\twhere rqp.Parent_Key IS NOT NULL\n\tAnd Role.Role_Name NOT LIKE '%!Closed%'\n\tAnd pers.Date_Leaving>Getdate()\n\t\n\tAnd (posti.Posting_sDate=(Select max(posti2.Posting_sDate) from Posting posti2 where posti.Id_Number=posti2.Id_number and posti2.Posting_sDate<=GetDate()) OR posti.Posting_sDate IS NULL)\n\t) b \n\t\n\nwhere a.Id_Number=b.Id_Number\nand a.ql_Qualification_Id=b.ql_Qualification_Id\nand a.Date_Last_mod > '@{activity('lk_get_pipeline_parameters').output.firstRow.start_date}'",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_maps_person_qualification_source",
						"type": "DatasetReference"
					}
				],
				"outputs": [
