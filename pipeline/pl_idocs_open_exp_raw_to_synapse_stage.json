									"disableMetricsCollection": false
								},
								"enableStaging": true,
								"stagingSettings": {
									"linkedServiceName": {
										"referenceName": "ADLSG2 TimeAnalytics DEV",
										"type": "LinkedServiceReference"
									},
									"path": "mdr-raw-data/Polybase_Staging_Space"
								},
								"translator": {
									"type": "TabularTranslator",
									"mappings": [
										{
											"source": {
												"name": "PROJECT NO.",
												"type": "String"
											},
											"sink": {
												"name": "project_number",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "PROJECT ID",
												"type": "String"
											},
											"sink": {
												"name": "project_id",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "PROJECT NAME",
												"type": "String"
											},
											"sink": {
												"name": "project_name",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "DOC ID",
												"type": "String"
											},
											"sink": {
												"name": "document_id",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "DELIVERABLE",
												"type": "String"
											},
											"sink": {
												"name": "deliverable",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "DOCUMENT NUMBER",
												"type": "String"
											},
											"sink": {
												"name": "document_number",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "EXPEDITED ISSUE STATE",
												"type": "String"
											},
											"sink": {
												"name": "document_status",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "TYPE CLASS",
												"type": "String"
											},
											"sink": {
												"name": "type_class",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "EXPEDITED VERSION",
												"type": "String"
											},
											"sink": {
												"name": "expedited_version",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "EXPEDITED REVISION",
												"type": "String"
											},
											"sink": {
												"name": "expedited_revision",
												"type": "String"
											}
										},
										{
											"source": {
