											},
											"sink": {
												"name": "user_type",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "RECIPIENT",
												"type": "String"
											},
											"sink": {
												"name": "recipient",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "COMPANY",
												"type": "String"
											},
											"sink": {
												"name": "company",
												"type": "String"
											}
										},
										{
											"source": {
												"name": "EXPEDITING START",
												"type": "String"
											},
											"sink": {
												"name": "expediting_start",
												"type": "String"
