			{
				"name": "lk_get_pipeline_parameters_2",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderStoredProcedureName": "getPipelineParametersValues",
						"storedProcedureParameters": {
							"pPipelineCode": {
								"type": "String",
								"value": {
									"value": "@pipeline().Pipeline",
									"type": "Expression"
								}
							},
							"pPipeLineSubCode": {
								"type": "String",
								"value": "NetworkFolder"
							}
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_azure_synapse_parameter",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "cp_copy_first_sheet_from_source_to_synapse",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "delete_Month_end_date",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.07:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "OracleSource",
						"additionalColumns": [
							{
								"name": "CreatedDateTime",
								"value": {
									"value": "@addHours(utcNow(),4 )",
									"type": "Expression"
								}
							},
							{
								"name": "project_number",
								"value": {
									"value": "@pipeline().parameters.proj_id",
									"type": "Expression"
								}
							}
						],
						"oracleReaderQuery": {
							"value": "select  m_sys.m_pck_site_sort.sort_loc(ivi.loc_id)  location, \n                m_sys.m_pck_site_sort.sort_smst(ivi.smst_id) status,\n                ivi.loc_id,\n                ivi.ivi_id,\n                m_sys.m_pck_mscm.get_ident_code(ivi.IDENT) IDENT_CODE,\n                m_sys.m_pck_receive.get_inv_recv_qty(ivi.ivi_id) recv_qty,\n                m_sys.m_pck_receive.get_resv_qty(ivi.ivi_id)  resv_qty,\n                nvl(m_sys.m_pck_receive.get_recv_qty(ivi.ivi_id),0) recv_by_recv,\n                ivi.issue_qty,\n                ivi.tag_number,\n                ivi.smst_id,\n                ivi.ident,\n                ivi.wh_id,\n                m_sys.m_pck_ident_infos.get_size(ivi.ident,1) INPUT_1    ,\n                m_sys.m_pck_ident_infos.get_size(ivi.ident,2) INPUT_2    ,\n                m_sys.m_pck_ident_infos.get_size(ivi.ident,3) INPUT_3    ,\n                m_sys.m_pck_ident_infos.get_size(ivi.ident,4) INPUT_4    ,\n                m_sys.m_pck_ident_infos.get_size(ivi.ident,5) INPUT_5    ,\n                ivi.unit_id,\n                ivi.heat_id,\n                m_sys.m_pck_receive.get_onhand_qty(ivi.IVI_ID) onhand_qty, \n                m_sys.M_PCK_IDENTS.get_commodity_code(ivi.ident) commodity_code,\n                m_sys.m_pck_std_custom.ident_desc(ivi.ident, 1) \"Ident Description\"\n                ,ivi.IDENT_DEVIATION,\n                ivi.PLATE_ID\nfrom m_sys.m_inv_items ivi\nwhere proj_id = ('@{pipeline().parameters.proj_id}')\norder by   m_sys.m_pck_site_sort.sort_smst(ivi.smst_id) ,m_sys.m_pck_site_sort.sort_wh(ivi.wh_id), m_sys.m_pck_estimate.sort_est_cs(ivi.ident)\n",
							"type": "Expression"
						},
						"partitionOption": "None",
						"convertDecimalToInteger": false,
						"queryTimeout": "02:00:00"
					},
					"sink": {
						"type": "SqlDWSink",
						"allowCopyCommand": true,
						"disableMetricsCollection": false
					},
					"enableStaging": true,
					"stagingSettings": {
						"linkedServiceName": {
							"referenceName": "ADLSG2 TimeAnalytics DEV",
							"type": "LinkedServiceReference"
						},
						"path": "mdr-staging-data/Ruya11"
					}
				},
				"inputs": [
					{
						"referenceName": "ds_smat_11_extracts",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "ds_excel_loads_AzureSynapseAnalytics",
						"type": "DatasetReference",
						"parameters": {
							"TableName": {
								"value": "@activity('lk_get_pipeline_parameters_2').output.firstRow.table_name",
								"type": "Expression"
							}
						}
					}
				]
			},
			{
				"name": "Send Email On Failure",
				"type": "WebActivity",
				"dependsOn": [
					{
						"activity": "Update_Month_end_date",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "POST",
					"headers": {
						"Content-Type": "application/json"
					},
					"url": "https://prod-31.eastus.logic.azure.com:443/workflows/03d7da5abbab4215a05aeaceae3b96fa/triggers/manual/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=asuyutHtoSxGFURsj1-A6AKRiNLdXZ4mTnZvZ17_8hI",
					"connectVia": {
						"referenceName": "integrationRuntimeEast2",
						"type": "IntegrationRuntimeReference"
					},
					"body": {
						"value": "{\n    \"DataFactoryName\": \"@{pipeline().DataFactory}\",\n    \"PipelineName\": \"@{pipeline().Pipeline}\",\n    \"ErrorMessage\": \"Pipeline Failed\",\n    \"EmailTo\": \"@{activity('lk_get_pipeline_parameters').output.firstRow.ncsa_master_pipeline_email_to}\",\n    \"Activity\":  \"pl_Receipt_Quantity_All_Projects\"\n}",
						"type": "Expression"
					}
				}
			},
			{
				"name": "delete_Month_end_date",
				"type": "Script",
				"dependsOn": [
					{
						"activity": "lk_get_pipeline_parameters",
						"dependencyConditions": [
							"Succeeded"
						]
					},
					{
						"activity": "lk_get_pipeline_parameters_2",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "AzureSynapseAnalytics",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"parameters": [
								{
									"name": "proj_id",
									"type": "String",
									"value": {
										"value": "@pipeline().parameters.proj_id",
										"type": "Expression"
									},
									"direction": "Input"
								}
							],
							"type": "Query",
							"text": {
								"value": "@concat('delete from [epr].[',activity('lk_get_pipeline_parameters_2').output.firstRow.table_name,']','\nwhere month_end_date = EOMONTH (getdate() , -1 )\nand project_number = ','''',pipeline().parameters.proj_id,'''')",
								"type": "Expression"
							}
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			},
			{
				"name": "Update_Month_end_date",
				"type": "Script",
				"dependsOn": [
					{
						"activity": "cp_copy_first_sheet_from_source_to_synapse",
						"dependencyConditions": [
							"Succeeded"
