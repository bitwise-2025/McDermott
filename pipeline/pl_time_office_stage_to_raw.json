				"dependsOn": [
					{
						"activity": "Set employee filename",
						"dependencyConditions": [
							"Succeeded"
						]
					},
					{
						"activity": "Set employee folderpath",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.01:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_adlsg2_csv_ncsa_time_office_employee_master_source",
