								{
									"referenceName": "ds_adlsg2_csv_parameter_generic",
									"type": "DatasetReference",
									"parameters": {
										"p_ds_filename": {
											"value": "@{concat('/',formatDateTime(utcnow(),'yyyy'),'/',formatDateTime(utcnow(),'MM'),'/',formatDateTime(utcnow(),'dd'),'/',variables('v_employee_filename'), '_', formatDateTime(utcnow(),'yyyy-MM-dd THHmmss'), '.csv')  }",
