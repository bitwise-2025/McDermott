{
	"name": "pl_yardkpi_pqr_stage_to_raw",
	"properties": {
		"activities": [
			{
				"name": "lk_get_pipeline_parameters",
				"description": "Get the parameters to be used in this pipeline",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderStoredProcedureName": "getPipelineParametersValues",
						"storedProcedureParameters": {
							"pPipelineCode": {
								"type": "String",
								"value": {
									"value": "@pipeline().Pipeline",
									"type": "Expression"
								}
							},
							"pPipeLineSubCode": {
								"type": "String",
								"value": {
									"value": "PQR",
									"type": "Expression"
								}
							}
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_azure_synapse_parameter",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "Check File Exists",
				"description": "Checking if the Stage file is available before progressing to the next activity.",
				"type": "GetMetadata",
				"dependsOn": [
					{
						"activity": "lk_get_pipeline_parameters",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_adlsg2_pqr_stg_generic",
						"type": "DatasetReference",
						"parameters": {
							"p_ds_filename": {
								"value": "@coalesce(null)",
								"type": "Expression"
							},
							"p_ds_folderpath": {
								"value": "@activity('lk_get_pipeline_parameters').output.firstRow.directory",
								"type": "Expression"
							},
							"p_ds_filesystem": {
								"value": "@activity('lk_get_pipeline_parameters').output.firstRow.input_file_system",
								"type": "Expression"
							}
						}
					},
					"fieldList": [
						"childItems"
					],
					"storeSettings": {
						"type": "AzureBlobFSReadSettings",
						"recursive": true,
						"enablePartitionDiscovery": false
					},
					"formatSettings": {
						"type": "DelimitedTextReadSettings"
					}
				}
			},
			{
				"name": "Set_File_Exists_status",
				"description": "Compare the results of the GetMetadata against the file present in the Stage location",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "Check File Exists",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "p_pl_fileexists",
					"value": {
						"value": "@greaterOrEquals(indexof(string(activity('Check File Exists').output.childItems),'STATUSWPSPQRQUALIFICATION'),0)",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Run copy if File Exists",
				"description": "Execute if a valid stage file is present",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "Set_File_Exists_status",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@variables('p_pl_fileexists')",
						"type": "Expression"
					},
					"ifTrueActivities": [
						{
							"name": "df_pqr_stage_to_raw",
							"type": "ExecuteDataFlow",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataflow": {
									"referenceName": "df_pqr_stage_to_raw",
									"type": "DataFlowReference",
									"datasetParameters": {
										"PQRStage": {
											"p_ds_filename": {
												"value": "@activity('lk_get_pipeline_parameters').output.firstRow.input_file_name_stg",
												"type": "Expression"
											},
											"p_ds_folderpath": {
												"value": "@activity('lk_get_pipeline_parameters').output.firstRow.Directory",
												"type": "Expression"
											},
											"p_ds_filesystem": {
												"value": "@activity('lk_get_pipeline_parameters').output.firstRow.input_file_system",
												"type": "Expression"
											}
										}
									}
								},
								"compute": {
									"coreCount": 8,
									"computeType": "General"
								},
								"traceLevel": "Fine"
							}
						}
					]
				}
			}
		],
		"variables": {
			"v_filename": {
				"type": "String"
			},
			"v_folderpath": {
				"type": "String"
			},
			"p_pl_fileexists": {
				"type": "Boolean"
			}
		},
		"folder": {
			"name": "Projects/YARD KPI/PQR"
		},
		"annotations": [],
		"lastPublishTime": "2024-01-12T10:37:08Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}