				"type": "Copy",
				"dependsOn": [
					{
						"activity": "Update_Week_end_date",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.07:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "OracleSource",
						"additionalColumns": [
							{
								"name": "CreatedDateTime",
								"value": {
									"value": "@addHours(utcNow(),4 )",
									"type": "Expression"
								}
							}
						],
						"oracleReaderQuery": {
							"value": "SELECT DISTINCT\n    r.proj_id project_id,\n    proj.description Project_Title,\n    r.r_id,\n    r.r_code requisition_no,\n    r_nls.short_desc Req_Short_Desc,\n    r_nls.Description Req_Desc,\n    r.r_supp req_rev,\n    r.created_date req_created_date,\n    r.rel_to_proc_date released_to_proc,\n    r.approved_date req_approved_date,\n    r.proc_acknowledge_date proc_ack_date\nFROM\n  m_sys.m_reqs r, \n  m_sys.m_req_nls r_nls,\n  m_sys.m_projects proj\nWHERE 1=1\n  AND r.proj_id = '@{pipeline().parameters.proj_id}'\n  AND r.proj_id = proj.proj_id\n  AND r.r_code like '%MR%'\n  AND r.actual_ind = 'N'\n  AND r.r_supp = '0'\n  AND r.r_id = r_nls.r_id\n  AND r_nls.nls_id = 1\nORDER BY project_id, r.r_code\n\n",
							"type": "Expression"
						},
						"partitionOption": "None",
						"convertDecimalToInteger": false,
						"queryTimeout": "02:00:00"
					},
					"sink": {
						"type": "SqlDWSink",
						"allowCopyCommand": true,
						"disableMetricsCollection": false
					},
					"enableStaging": true,
					"stagingSettings": {
						"linkedServiceName": {
							"referenceName": "ADLSG2 TimeAnalytics DEV",
							"type": "LinkedServiceReference"
						},
						"path": "mdr-staging-data/Ruya11"
					}
				},
				"inputs": [
					{
						"referenceName": "ds_smat_11_extracts",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "ds_excel_loads_AzureSynapseAnalytics",
						"type": "DatasetReference",
						"parameters": {
							"TableName": {
								"value": "@activity('lk_get_pipeline_parameters_2').output.firstRow.table_name",
								"type": "Expression"
							}
						}
					}
				]
			},
			{
