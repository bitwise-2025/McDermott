{
	"name": "pl_yardkpi_toolhound_inventory_stage_to_raw",
	"properties": {
		"description": "YarKPI Toolhound Inventory stage to raw pipeline\n\n",
		"activities": [
			{
				"name": "lk_get_pipeline_parameters",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderStoredProcedureName": "[dbo].[getPipelineParametersValues]",
						"storedProcedureParameters": {
							"pPipelineCode": {
								"type": "String",
								"value": {
									"value": "@pipeline().Pipeline",
									"type": "Expression"
								}
							},
							"pPipeLineSubCode": {
								"type": "String",
								"value": {
									"value": "Toolhound",
									"type": "Expression"
								}
							}
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_azure_synapse_parameter",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "Check File Exists",
				"description": "Checking if the Stage file is available before progressing to the next activity.",
				"type": "GetMetadata",
				"dependsOn": [
					{
						"activity": "lk_get_pipeline_parameters",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "ds_adlsg2_csv_yardkpi_toolhound_inventory",
						"type": "DatasetReference",
						"parameters": {
							"p_ds_filesystem": {
								"value": "@activity('lk_get_pipeline_parameters').output.firstRow.input_file_system",
								"type": "Expression"
							},
							"p_ds_directory": {
								"value": "@activity('lk_get_pipeline_parameters').output.firstRow.folder_path",
								"type": "Expression"
							},
							"p_ds_filename": {
								"value": "@concat(activity('lk_get_pipeline_parameters').output.firstRow.file_name,'.csv')",
								"type": "Expression"
							}
						}
					},
					"fieldList": [
						"size",
						"exists"
					],
					"storeSettings": {
						"type": "AzureBlobFSReadSettings",
						"recursive": true,
						"enablePartitionDiscovery": false
					},
					"formatSettings": {
						"type": "DelimitedTextReadSettings"
					}
				}
			},
			{
				"name": "Run copy if File Exists",
				"description": "Execute if a valid stage file is present",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "Check File Exists",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@greater(activity('Check File Exists').output.size, 2)",
						"type": "Expression"
					},
					"ifTrueActivities": [
						{
							"name": "df_toolhound_inventory_stage_to_raw",
							"type": "ExecuteDataFlow",
							"dependsOn": [],
							"policy": {
								"timeout": "7.00:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataflow": {
									"referenceName": "df_Toolhound_inventory_stage_to_raw",
									"type": "DataFlowReference",
									"datasetParameters": {
										"SrcToolhoundStage": {
											"p_ds_filesystem": {
												"value": "@activity('lk_get_pipeline_parameters').output.firstRow.input_file_system",
												"type": "Expression"
											},
											"p_ds_directory": {
												"value": "@activity('lk_get_pipeline_parameters').output.firstRow.folder_path",
												"type": "Expression"
											},
											"p_ds_filename": {
												"value": "@concat(activity('lk_get_pipeline_parameters').output.firstRow.file_name,'.csv')",
												"type": "Expression"
											}
										},
										"SinkToolhoundRaw": {
											"p_ds_filesystem": {
												"value": "@activity('lk_get_pipeline_parameters').output.firstRow.output_file_system",
												"type": "Expression"
											},
											"p_ds_directory": {
												"value": "@activity('lk_get_pipeline_parameters').output.firstRow.folder_path",
												"type": "Expression"
											}
										}
									}
								},
								"integrationRuntime": {
									"referenceName": "integrationRuntimeEast2",
									"type": "IntegrationRuntimeReference"
								},
								"traceLevel": "Fine"
							}
						}
					]
				}
			}
		],
		"variables": {
			"v_allrev_src_start_time": {
				"type": "String"
			},
			"p_pl_fileexists": {
				"type": "String"
			}
		},
		"folder": {
			"name": "Projects/YARD KPI/Toolhound/Inventory"
		},
		"annotations": [],
		"lastPublishTime": "2023-11-17T05:36:05Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}