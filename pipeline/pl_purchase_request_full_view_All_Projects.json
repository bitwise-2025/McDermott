				"policy": {
					"timeout": "0.07:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "OracleSource",
						"additionalColumns": [
							{
								"name": "CreatedDateTime",
								"value": {
									"value": "@addHours(utcNow(),4 )",
									"type": "Expression"
								}
							}
						],
						"oracleReaderQuery": {
							"value": "SELECT r.PROJ_ID \n,d.DP_CODE as Discipline\n,r.R_CODE as Requisition_no\n,r.R_SUPP as Supp\n,r.ACTUAL_IND\n,r.MR_REVISION\n,r.SR_REVISION\n,R_ORIGIN_CODE\n,rst.RST_CODE as Status--revision_id\n--,decode(R_RELEASE_CONTEXT, 'ALL','All Quantities','SHQ','Shortage Quantities','SUQ','Surplus Quantities','CHQ','Changed Quantities','NLI','New Line Items')\n,APPROVED_BY\n,APPROVED_DATE\n,ORIGINATOR\n,REL_TO_PROC_BY\n,REL_TO_PROC_DATE\n,BUYER\n,PROC_ACKNOWLEDGE_DATE\n,INQ_COMPLETE_IND\n,PO_COMPLETE_IND\n--,R_ATTRIBUTE_1\n,ORIGINAL_BUDGET\n,replace(replace(n.SHORT_DESC,'|',' '),',',' ')as Short_Description\n,replace(replace(n.DESCRIPTION,'|',' '),',',' ') as DESCRIPTION\n--,m_pck_req_util.get_rnd_codes (r.rnd_id, '/', 255)\n,MT.MTY_CODE\n,MJ.MJ_CODE\n,MTE.RTP_CODE\n,mrn.rnd_code\n,mrd.RSD_CODE\n,CREATED_DATE \nFROM \n  M_SYS.m_reqs r, \n  m_sys.m_req_status rst,\n  m_sys.mvp_er_workload  w,\n  m_sys.m_disciplines  d,\n  M_SYS.M_REQ_NLS n,\n  m_sys.m_mto_types mt,\n  m_sys.m_mto_jobs mj, \n  m_sys.m_req_templs mte,\n  m_sys.m_req_nodes mrn, \n  m_sys.m_req_set_details mrd\nwhere d.dp_id(+) = r.dp_id  \nand w.r_id(+)   = r.R_ID  \nand n.r_id(+)   = r.R_ID\nand mt.mty_id(+)   = r.mty_id \nand mt.proj_id(+)  = r.proj_id --\nand mj.mj_id(+)    = r.mj_id \nand mj.proj_id(+)  = r.proj_id --\nand mte.rtp_id(+)  = r.rtp_id \nand mte.proj_id(+) = r.proj_id --\nand mrn.rnd_id(+)  = r.rnd_id \nand mrn.proj_id(+) = r.proj_id --\nand mrd.rsd_id(+)  = r.rsd_id \nand mrd.proj_id(+) = r.proj_id\nand r.rst_id = rst.rst_id \nand r.r_supp in(          \n(select  max(r_supp) r_supp from m_sys.m_reqs\nwhere r_code =r.r_code\nand   rst.proj_id   = r.Proj_id))\nand r.proj_id = '@{pipeline().parameters.proj_id}'",
							"type": "Expression"
						},
						"partitionOption": "None",
						"convertDecimalToInteger": false,
						"queryTimeout": "02:00:00"
					},
					"sink": {
						"type": "SqlDWSink",
						"allowCopyCommand": true,
						"disableMetricsCollection": false
					},
