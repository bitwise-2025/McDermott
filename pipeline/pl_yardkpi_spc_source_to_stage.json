{
	"name": "pl_yardkpi_spc_source_to_stage",
	"properties": {
		"activities": [
			{
				"name": "lk_get_pipeline_parameters",
				"description": "Get the parameters to be used in this pipeline",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderStoredProcedureName": {
							"value": "dbo.getPipelineParametersValues",
							"type": "Expression"
						},
						"storedProcedureParameters": {
							"pPipelineCode": {
								"type": "String",
								"value": {
									"value": "@pipeline().Pipeline",
									"type": "Expression"
								}
							},
							"pPipeLineSubCode": {
								"type": "String",
								"value": {
									"value": "@pipeline().parameters.PipeLineSubCode",
									"type": "Expression"
								}
							}
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_azure_synapse_parameter",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "ForEachTable",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "lk_get_pipeline_parameters",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@split(activity('lk_get_pipeline_parameters').output.firstRow.schema_table,',')",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "CP_SPC_to_Stage",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "7.00:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "OracleSource",
									"additionalColumns": [
										{
											"name": "source_code",
											"value": {
												"value": "@activity('lk_get_pipeline_parameters').output.firstRow.source_name",
												"type": "Expression"
											}
										},
										{
											"name": "sub_source_code",
											"value": {
												"value": "@activity('lk_get_pipeline_parameters').output.firstRow.sub_source_name",
												"type": "Expression"
											}
										}
									],
									"partitionOption": "None",
									"queryTimeout": "02:00:00"
								},
								"sink": {
									"type": "DelimitedTextSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings"
									},
									"formatSettings": {
										"type": "DelimitedTextWriteSettings",
										"quoteAllText": true,
										"fileExtension": ".txt"
									}
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_oracle_db_yardkpi_spc_source",
									"type": "DatasetReference",
									"parameters": {
										"ds_p_tablename": {
											"value": "@split(item(),'|')[3]",
											"type": "Expression"
										},
										"ds_p_hostname": {
											"value": "@split(item(),'|')[0]",
											"type": "Expression"
										},
										"ds_p_port": {
											"value": "@split(item(),'|')[1]",
											"type": "Expression"
										},
										"ds_p_database": {
											"value": "@split(item(),'|')[2]",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_adgl2_csv_yardkpi_spc_source",
									"type": "DatasetReference",
									"parameters": {
										"p_ds_filesystem": {
											"value": "@activity('lk_get_pipeline_parameters').output.firstRow.output_file_system",
											"type": "Expression"
										},
										"p_ds_directory": {
											"value": "@activity('lk_get_pipeline_parameters').output.firstRow.folder_path",
											"type": "Expression"
										},
										"p_ds_filename": {
											"value": "@concat(activity('lk_get_pipeline_parameters').output.firstRow.file_name,'_',item(),'_',replace(replace(utcNow(),'.','-'),':','-'),'.csv')",
											"type": "Expression"
										}
									}
								}
							]
						}
					]
				}
			}
		],
		"parameters": {
			"PipeLineSubCode": {
				"type": "string",
				"defaultValue": "SPC"
			}
		},
		"folder": {
			"name": "Projects/YARD KPI/SPC"
		},
		"annotations": [],
		"lastPublishTime": "2024-07-17T13:01:00Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}