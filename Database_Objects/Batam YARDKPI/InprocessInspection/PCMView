CREATE VIEW [yardkpi].[stage_ent_contract_pcm_vw] AS 
select 
  ROW_NUMBER() over(
    ORDER BY 
      contract ASC
  ) as rowID, 
  source_code, 
  sub_source_code, 
  contract, 
  contract_title, 
  contract as project_number, 
  LastUpdate 
from 
  (
    select 
      distinct 'SYSTEM' as source_code, 
      'PCM' as sub_source_code, 
      contract, 
      contract_title, 
      contract as project_number, 
      getdate() LastUpdate 
    from 
      [yardkpi].[stage_entp_pcm_Weld_details] dcsr 
    where 
      not exists (
        select 
          1 
        from 
          dbo.dim_ent_contract 
        where 
          contract_number = dcsr.contract 
          and active = 1
      ) 
    Union 
    select 
      distinct 'SYSTEM' as source_code, 
      'PCM' as sub_source_code, 
      contract, 
      contract_title, 
      contract as project_number, 
      getdate() LastUpdate 
    from 
      [yardkpi].[stage_entp_pcm_Welder_activity] dcsr 
    where 
      not exists (
        select 
          1 
        from 
          dbo.dim_ent_contract 
        where 
          contract_number = dcsr.contract 
          and active = 1
      ) 
    union 
    select 
      distinct 'SYSTEM' as source_code, 
      'PCM' as sub_source_code, 
      contract, 
      contract_title, 
      contract as project_number, 
      getdate() LastUpdate 
    from 
      [yardkpi].[stage_entp_pcm_ndt_details] dcsr 
    where 
      not exists (
        select 
          1 
        from 
          dbo.dim_ent_contract 
        where 
          contract_number = dcsr.contract 
          and active = 1
      ) 
    union 
    select 
      distinct 'SYSTEM' as source_code, 
      'PCM' as sub_source_code, 
      contract, 
      contract_title, 
      contract as project_number, 
      getdate() LastUpdate 
    from 
      [yardkpi].[stage_entp_pcm_certification_package] dcsr 
    where 
      not exists (
        select 
          1 
        from 
          dbo.dim_ent_contract 
        where 
          contract_number = dcsr.contract 
          and active = 1
      ) 
    union 
    select 
      distinct 'SYSTEM' as source_code, 
      'PCM' as sub_source_code, 
      contract, 
      contract_title, 
      contract as project_number, 
      getdate() LastUpdate 
    from 
      [yardkpi].[stage_entp_pcm_paint_detail] dcsr 
    where 
      not exists (
        select 
          1 
        from 
          dbo.dim_ent_contract 
        where 
          contract_number = dcsr.contract 
          and active = 1
      )
	    union 
    select 
      distinct 'SYSTEM' as source_code, 
      'PCM' as sub_source_code, 
      contract, 
      contract_title, 
      contract as project_number, 
      getdate() LastUpdate 
    from 
      [yardkpi].[stage_entp_pcm_inprocess_inspection] dcsr 
    where 
      not exists (
        select 
          1 
        from 
          dbo.dim_ent_contract 
        where 
          contract_number = dcsr.contract 
          and active = 1
      )
  ) disa;
