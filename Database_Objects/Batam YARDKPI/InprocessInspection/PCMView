CREATE VIEW [yardkpi].[stage_entp_pcm_job_item_vw]
AS
  SELECT Row_number()
           OVER(
             ORDER BY job ASC) AS rowID,
         job,
         job_title,
         item,
         item_title,
         fab_code,
         contract,
         contract_title,
        -- include_in_rr_calc,
         lastupdate
  FROM   (SELECT DISTINCT job,
                          job_title,
                          item,
                          item_title,
                          fab_code,
                          contract,
                          contract_title,
                      --    include_in_rr_calc,
                          Getdate() LastUpdate
          FROM   [yardkpi].[stage_entp_pcm_weld_details] dcsr
          WHERE  NOT EXISTS(SELECT 1
                            FROM   dbo.dim_entp_pcm_job_item_vw dm
                            WHERE  dm.job = dcsr.job
                                   AND dm.item = dcsr.item
                                   AND dm.fab_code = dcsr.fab_code
                                   AND dm.contract = dcsr.contract)
          UNION
          SELECT DISTINCT job,
                          job_title,
                          item,
                          item_title,
                          fab_code,
                          contract,
                          contract_title,
                        --  include_in_rr_calc,
                          Getdate() LastUpdate
          FROM   [yardkpi].[stage_entp_pcm_welder_activity] dcsr
          WHERE  NOT EXISTS(SELECT 1
