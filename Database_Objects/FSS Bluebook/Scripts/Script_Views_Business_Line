  ) M
where NOT EXISTS(select 1 from dim_entp_fss_business_line_v P where M.business_line = P.business_line)
and isnull(business_line,'')<>''
AND business_line NOT IN ('Backlog Projects'
,'Business Line'
,'New Awards'
,'Project Title'
,'Total')
AND 1=2;

GO


