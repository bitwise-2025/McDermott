/*Adding new business line values from the transaction data has been disabled by the condition "and 1=2" Dtae : 03/05/2024 
based on business requirement. To add or change business line values , a new IT ticket to be initiated and execute script manually*/

DROP VIEW [fss].[stage_fss_business_line_v]
GO
CREATE VIEW [fss].[stage_fss_business_line_v] AS select distinct
   ROW_NUMBER() over(ORDER BY business_line ASC) as  stage_fss_business_line_id,
   source_Code,
sub_source_Code,
      business_line,
      alternative_business_line,
reporting_order
from
(SELECT DISTINCT cast('Manual' as varchar(50)) as source_Code
                ,cast('Excel' as varchar(50)) as sub_source_Code
                ,ISNULL(cast([Business Line] as varchar(200)),'') as business_line
                ,ISNULL(cast([Business Line] as varchar(200)),'') as alternative_business_line,
1 as [reporting_order] 
      FROM
  fss.stage_fss_neworders_v  
  union 
  SELECT DISTINCT cast('Manual' as varchar(50)) as source_Code
                ,cast('Excel' as varchar(50)) as sub_source_Code
                ,ISNULL(cast([Business Line] as varchar(200)),'') as business_line
                ,ISNULL(cast([Business Line] as varchar(200)),'') as alternative_business_line,
1 as [reporting_order] 
      FROM
  fss.stage_fss_revenue_v
  

  union 
  SELECT DISTINCT cast('Manual' as varchar(50)) as source_Code
                ,cast('Excel' as varchar(50)) as sub_source_Code
                ,ISNULL(cast([Business Line] as varchar(200)),'') as business_line
                ,ISNULL(cast([Business Line] as varchar(200)),'') as alternative_business_line,
1 as [reporting_order] 
      FROM
  fss.stage_fss_gross_profit_v

  union
  
  SELECT DISTINCT cast('Manual' as varchar(50)) as source_Code
                ,cast('Excel' as varchar(50)) as sub_source_Code
                ,ISNULL(cast([Business Line] as varchar(200)),'') as business_line
                ,ISNULL(cast([Business Line] as varchar(200)),'') as alternative_business_line,
1 as [reporting_order] 
      FROM
  fss.stage_fss_PandL_v
  
  union

   SELECT DISTINCT cast('Manual' as varchar(50)) as source_Code
                ,cast('Excel' as varchar(50)) as sub_source_Code
                ,ISNULL(cast([Business Line] as varchar(200)),'') as business_line
                ,ISNULL(cast([Business Line] as varchar(200)),'') as alternative_business_line,
1 as [reporting_order] 
      FROM
  fss.stage_fss_PandL_YTD_v

  union

  SELECT DISTINCT cast('Manual' as varchar(50)) as source_Code
                ,cast('Excel' as varchar(50)) as sub_source_Code
                ,ISNULL(cast([Business Line] as varchar(200)),'') as business_line
                ,ISNULL(cast([Business Line] as varchar(200)),'') as alternative_business_line,
